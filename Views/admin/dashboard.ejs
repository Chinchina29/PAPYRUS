<%- include('../partials/admin-header', { pageTitle: 'Dashboard' }) %>

<%- include('../partials/admin-sidebar', { currentPage: 'dashboard' }) %>

<div class="main-content">
    <!-- Top Header -->
    <div class="top-header">
        <div class="search-bar">
            <input type="text" class="search-input" placeholder="Search for books, authors...">
        </div>
        
        <div class="header-actions">
            <button class="notification-btn">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M6 8a6 6 0 0 1 12 0c0 7 3 9 3 9H3s3-2 3-9"/>
                    <path d="M13.73 21a2 2 0 0 1-3.46 0"/>
                </svg>
            </button>
            
            <div class="admin-info">
                <div class="admin-panel-text">Admin Panel</div>
                <div class="admin-name"><%= user?.firstName || 'Admin' %> <%= user?.lastName || 'User' %></div>
            </div>
        </div>
    </div>

    <!-- Dashboard Content -->
    <div class="dashboard-content">
        <!-- Page Header -->
        <div class="page-header">
            <div class="page-title">
                <h1>Dashboard Overview</h1>
                <p>Welcome back. Here's what's happening in the library today.</p>
            </div>
            
            <div class="page-actions">
                <button class="filter-btn">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M8 6h13"/>
                        <path d="M6 12h9"/>
                        <path d="M4 18h7"/>
                    </svg>
                    Last 30 Days
                </button>
                <button class="export-btn">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
                        <polyline points="7,10 12,15 17,10"/>
                        <line x1="12" y1="15" x2="12" y2="3"/>
                    </svg>
                    Export Report
                </button>
            </div>
        </div>

        <!-- Stats Cards -->
        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                        <circle cx="8.5" cy="7" r="4"/>
                        <line x1="20" y1="8" x2="20" y2="14"/>
                        <line x1="23" y1="11" x2="17" y2="11"/>
                    </svg>
                </div>
                <div class="stat-content">
                    <div class="stat-value">$42,850.00</div>
                    <div class="stat-label">Total Sales</div>
                    <div class="stat-change positive">+12.5%</div>
                </div>
            </div>

            <div class="stat-card">
                <div class="stat-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                        <circle cx="9" cy="7" r="4"/>
                        <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
                        <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                    </svg>
                </div>
                <div class="stat-content">
                    <div class="stat-value">2,482</div>
                    <div class="stat-label">Active Users</div>
                    <div class="stat-change positive">+8.2%</div>
                </div>
            </div>

            <div class="stat-card">
                <div class="stat-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/>
                        <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/>
                    </svg>
                </div>
                <div class="stat-content">
                    <div class="stat-value">18,540</div>
                    <div class="stat-label">Total Books</div>
                    <div class="stat-change neutral">Status</div>
                </div>
            </div>

            <div class="stat-card">
                <div class="stat-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>
                    </svg>
                </div>
                <div class="stat-content">
                    <div class="stat-value">124</div>
                    <div class="stat-label">New Listings</div>
                    <div class="stat-change positive">+18</div>
                </div>
            </div>
        </div>

        <!-- Charts Section -->
        <div class="charts-section">
            <div class="revenue-chart">
                <div class="chart-header">
                    <h3>Revenue Growth</h3>
                    <p>Monthly revenue performance</p>
                </div>
                <div class="chart-container">
                    <canvas id="revenueChart"></canvas>
                </div>
            </div>

            <div class="categories-chart">
                <div class="chart-header">
                    <h3>Categories</h3>
                    <p>Stock distribution</p>
                </div>
                <div class="chart-container">
                    <div class="donut-chart">
                        <div class="donut-center">
                            <div class="donut-value">1.2k</div>
                            <div class="donut-label">Books</div>
                        </div>
                    </div>
                    <div class="chart-legend">
                        <div class="legend-item">
                            <span class="legend-color" style="background: #8b7355;"></span>
                            <span class="legend-text">Classic Literature</span>
                            <span class="legend-percent">45%</span>
                        </div>
                        <div class="legend-item">
                            <span class="legend-color" style="background: #a68b5b;"></span>
                            <span class="legend-text">Historical</span>
                            <span class="legend-percent">30%</span>
                        </div>
                        <div class="legend-item">
                            <span class="legend-color" style="background: #c4a373;"></span>
                            <span class="legend-text">Other</span>
                            <span class="legend-percent">25%</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Recent Activity -->
        <div class="recent-activity">
            <div class="activity-header">
                <div>
                    <h3>Recent Listings & Transactions</h3>
                    <p>Activity awaiting your approval and recent orders</p>
                </div>
                <button class="view-all-btn">View All Activity</button>
            </div>

            <div class="activity-table">
                <div class="table-header">
                    <div class="header-cell">Reference</div>
                    <div class="header-cell">Item/Book Title</div>
                    <div class="header-cell">Curator/Buyer</div>
                    <div class="header-cell">Amount</div>
                    <div class="header-cell">Date</div>
                    <div class="header-cell">Status</div>
                </div>

                <div class="table-row">
                    <div class="table-cell">
                        <div class="reference">RP-8825</div>
                    </div>
                    <div class="table-cell">
                        <div class="book-info">
                            <div class="book-cover"></div>
                            <div class="book-details">
                                <div class="book-title">The Great Gatsby</div>
                                <div class="book-subtitle">First Edition Hardcover</div>
                            </div>
                        </div>
                    </div>
                    <div class="table-cell">John Doe</div>
                    <div class="table-cell">$1,450.00</div>
                    <div class="table-cell">Oct 26, 2023</div>
                    <div class="table-cell">
                        <span class="status-badge pending">Pending Approval</span>
                    </div>
                </div>

                <div class="table-row">
                    <div class="table-cell">
                        <div class="reference">BOOK-2794</div>
                    </div>
                    <div class="table-cell">
                        <div class="book-info">
                            <div class="book-cover"></div>
                            <div class="book-details">
                                <div class="book-title">Pride and Prejudice</div>
                                <div class="book-subtitle">Rare Edition</div>
                            </div>
                        </div>
                    </div>
                    <div class="table-cell">Elizabeth Bennet</div>
                    <div class="table-cell">$340.00</div>
                    <div class="table-cell">Oct 26, 2023</div>
                    <div class="table-cell">
                        <span class="status-badge shipped">Shipped</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
.dashboard-content {
    padding: 32px;
}

.page-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 32px;
}

.page-title h1 {
    font-size: 28px;
    font-weight: 600;
    color: #3a3a3a;
    margin-bottom: 4px;
}

.page-title p {
    color: #5a4d42;
    font-size: 14px;
}

.page-actions {
    display: flex;
    gap: 12px;
}

.filter-btn, .export-btn {
    padding: 10px 16px;
    border-radius: 8px;
    border: 1px solid #e8dcc8;
    background: white;
    color: #5a4d42;
    font-size: 14px;
    font-weight: 500;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 8px;
    transition: all 0.2s ease;
}

.export-btn {
    background: #8b7355;
    color: white;
    border-color: #8b7355;
}

.filter-btn:hover, .export-btn:hover {
    background: #5a4a3a;
    color: white;
    border-color: #5a4a3a;
}

.filter-btn svg, .export-btn svg {
    width: 16px;
    height: 16px;
}

.stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
    margin-bottom: 32px;
}

.stat-card {
    background: white;
    border-radius: 12px;
    padding: 24px;
    border: 1px solid #e8dcc8;
    display: flex;
    align-items: center;
    gap: 16px;
}

.stat-icon {
    width: 48px;
    height: 48px;
    border-radius: 8px;
    background: #f5f1ed;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #8b7355;
}

.stat-icon svg {
    width: 24px;
    height: 24px;
}

.stat-content {
    flex: 1;
}

.stat-value {
    font-size: 24px;
    font-weight: 700;
    color: #3a3a3a;
    margin-bottom: 4px;
}

.stat-label {
    font-size: 14px;
    color: #5a4d42;
    margin-bottom: 8px;
}

.stat-change {
    font-size: 12px;
    font-weight: 600;
    padding: 4px 8px;
    border-radius: 4px;
    display: inline-block;
}

.stat-change.positive {
    background: #d4edda;
    color: #155724;
}

.stat-change.neutral {
    background: #f8f9fa;
    color: #6c757d;
}

.charts-section {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 24px;
    margin-bottom: 32px;
}

.revenue-chart, .categories-chart {
    background: white;
    border-radius: 12px;
    padding: 24px;
    border: 1px solid #e8dcc8;
}

.chart-header {
    margin-bottom: 24px;
}

.chart-header h3 {
    font-size: 18px;
    font-weight: 600;
    color: #3a3a3a;
    margin-bottom: 4px;
}

.chart-header p {
    font-size: 14px;
    color: #5a4d42;
}

.chart-container {
    height: 300px;
    position: relative;
}

.donut-chart {
    width: 200px;
    height: 200px;
    border-radius: 50%;
    background: conic-gradient(#8b7355 0deg 162deg, #a68b5b 162deg 270deg, #c4a373 270deg 360deg);
    position: relative;
    margin: 0 auto 24px;
}

.donut-chart::before {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 120px;
    height: 120px;
    background: white;
    border-radius: 50%;
}

.donut-center {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    text-align: center;
    z-index: 1;
}

.donut-value {
    font-size: 24px;
    font-weight: 700;
    color: #3a3a3a;
}

.donut-label {
    font-size: 14px;
    color: #5a4d42;
}

.chart-legend {
    display: flex;
    flex-direction: column;
    gap: 12px;
}

.legend-item {
    display: flex;
    align-items: center;
    gap: 8px;
}

.legend-color {
    width: 12px;
    height: 12px;
    border-radius: 2px;
}

.legend-text {
    flex: 1;
    font-size: 14px;
    color: #5a4d42;
}

.legend-percent {
    font-size: 14px;
    font-weight: 600;
    color: #3a3a3a;
}

.recent-activity {
    background: white;
    border-radius: 12px;
    padding: 24px;
    border: 1px solid #e8dcc8;
}

.activity-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 24px;
}

.activity-header h3 {
    font-size: 18px;
    font-weight: 600;
    color: #3a3a3a;
    margin-bottom: 4px;
}

.activity-header p {
    font-size: 14px;
    color: #5a4d42;
}

.view-all-btn {
    padding: 8px 16px;
    border-radius: 6px;
    border: 1px solid #e8dcc8;
    background: white;
    color: #5a4d42;
    font-size: 14px;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s ease;
}

.view-all-btn:hover {
    background: #f5f1ed;
}

.activity-table {
    border: 1px solid #e8dcc8;
    border-radius: 8px;
    overflow: hidden;
}

.table-header {
    display: grid;
    grid-template-columns: 120px 2fr 1fr 120px 120px 140px;
    background: #f5f1ed;
    border-bottom: 1px solid #e8dcc8;
}

.header-cell {
    padding: 16px;
    font-size: 12px;
    font-weight: 600;
    color: #5a4d42;
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

.table-row {
    display: grid;
    grid-template-columns: 120px 2fr 1fr 120px 120px 140px;
    border-bottom: 1px solid #e8dcc8;
    align-items: center;
}

.table-row:last-child {
    border-bottom: none;
}

.table-cell {
    padding: 16px;
    font-size: 14px;
    color: #3a3a3a;
}

.reference {
    font-weight: 600;
    color: #8b7355;
}

.book-info {
    display: flex;
    align-items: center;
    gap: 12px;
}

.book-cover {
    width: 40px;
    height: 50px;
    background: #8b7355;
    border-radius: 4px;
    flex-shrink: 0;
}

.book-title {
    font-weight: 600;
    color: #3a3a3a;
    margin-bottom: 2px;
}

.book-subtitle {
    font-size: 12px;
    color: #5a4d42;
}

.status-badge {
    padding: 4px 12px;
    border-radius: 20px;
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

.status-badge.pending {
    background: #fff3cd;
    color: #856404;
}

.status-badge.shipped {
    background: #d1ecf1;
    color: #0c5460;
}

@media (max-width: 1200px) {
    .stats-grid {
        grid-template-columns: repeat(2, 1fr);
    }
    
    .charts-section {
        grid-template-columns: 1fr;
    }
}

@media (max-width: 768px) {
    .stats-grid {
        grid-template-columns: 1fr;
    }
    
    .page-header {
        flex-direction: column;
        gap: 16px;
    }
    
    .table-header, .table-row {
        grid-template-columns: 1fr;
    }
    
    .header-cell, .table-cell {
        padding: 8px 16px;
    }
}
</style>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
// Revenue Chart
const ctx = document.getElementById('revenueChart').getContext('2d');
new Chart(ctx, {
    type: 'bar',
    data: {
        labels: ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun'],
        datasets: [{
            data: [3200, 4100, 3800, 5200, 6100, 5800],
            backgroundColor: '#8b7355',
            borderRadius: 4,
            borderSkipped: false,
        }]
    },
    options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
            legend: {
                display: false
            }
        },
        scales: {
            y: {
                beginAtZero: true,
                grid: {
                    color: '#e8dcc8'
                },
                ticks: {
                    color: '#5a4d42'
                }
            },
            x: {
                grid: {
                    display: false
                },
                ticks: {
                    color: '#5a4d42'
                }
            }
        }
    }
});
</script>

</body>
</html>