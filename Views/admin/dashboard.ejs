<!DOCTYPE html>
<html class="light" lang="en">
<head>
    <meta charset="utf-8"/>
    <meta content="width=device-width, initial-scale=1.0" name="viewport"/>
    <title>Pappyrus Admin - Dashboard</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Public+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols_Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
    <script>
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary": "#1a2f23",
                        "sidebar": "#e8e0d5",
                        "accent": "#1a2f23",
                        "background-light": "#f2ede4",
                        "background-dark": "#221610",
                        "sidebar-text": "#4a3f35",
                        "brand-orange": "#ec5b13"
                    },
                    fontFamily: {
                        "display": ["Public Sans"]
                    },
                    borderRadius: {
                        "DEFAULT": "0.25rem",
                        "lg": "0.5rem",
                        "xl": "0.75rem",
                        "full": "9999px"
                    },
                },
            },
        }
    </script>
</head>
<body class="bg-background-light dark:bg-background-dark font-display text-slate-900 dark:text-slate-100 antialiased">
<div class="flex min-h-screen">
    <aside class="w-72 flex flex-col fixed inset-y-0 left-0 z-50 bg-[#e8e0d5] text-stone-800 border-r border-stone-300">
        <div class="p-6 flex flex-col gap-1">
            <h1 class="text-xl font-bold leading-normal flex items-center gap-2 text-accent">
                <span class="material-symbols-outlined text-accent">auto_stories</span>Pappyrus Admin
            </h1>
            <p class="text-stone-400 text-xs font-medium uppercase tracking-widest">Management Portal</p>
        </div>
        <nav class="flex-1 px-4 py-4 space-y-1 overflow-y-auto">
            <a class="flex items-center gap-3 px-3 py-2.5 rounded-lg bg-primary text-white shadow-md transition-colors" href="/admin/dashboard">
                <span class="material-symbols-outlined text-[22px]">dashboard</span>
                <span class="text-sm font-bold">Overview</span>
            </a>
            <a class="flex items-center gap-3 px-3 py-2.5 rounded-lg hover:bg-stone-200/50 transition-colors" href="/admin/users">
                <span class="material-symbols-outlined text-[22px] text-stone-500">group</span>
                <span class="text-sm font-medium">User Management</span>
            </a>
            <div class="pt-4 pb-2">
                <div class="h-px bg-stone-700/50 mx-3"></div>
            </div>
            <a class="flex items-center gap-3 px-3 py-2.5 rounded-lg hover:bg-stone-200/50 transition-colors" href="/admin/settings">
                <span class="material-symbols-outlined text-[22px] text-stone-500">settings</span>
                <span class="text-sm font-medium">Settings</span>
            </a>
        </nav>
        <div class="p-4 bg-stone-200/40">
            <div class="flex items-center gap-3">
                <div class="size-10 rounded-full bg-stone-700 flex items-center justify-center text-white font-bold">
                    <% if (user && user.firstName && user.lastName) { %>
                        <%= user.firstName.charAt(0) %><%= user.lastName.charAt(0) %>
                    <% } else { %>
                        A
                    <% } %>
                </div>
                <div class="flex-1 overflow-hidden text-ellipsis">
                    <p class="text-sm font-semibold truncate text-stone-800">
                        <% if (user && user.firstName && user.lastName) { %>
                            <%= user.firstName %> <%= user.lastName %>
                        <% } else { %>
                            Admin User
                        <% } %>
                    </p>
                    <p class="text-xs text-stone-400 truncate">Administrator</p>
                </div>
                <a href="/admin/logout">
                    <span class="material-symbols-outlined text-stone-500 cursor-pointer hover:text-stone-800">logout</span>
                </a>
            </div>
        </div>
    </aside>

    <main class="ml-72 flex-1 flex flex-col min-h-screen">
        <header class="h-16 bg-white/80 backdrop-blur-sm dark:bg-background-dark border-b border-stone-300 dark:border-stone-800 flex items-center justify-between px-8 sticky top-0 z-40">
            <div class="flex items-center gap-4 flex-1">
                <h2 class="text-xl font-bold text-accent whitespace-nowrap">Dashboard Overview</h2>
            </div>
            <div class="flex items-center gap-4">
                <button class="size-10 flex items-center justify-center rounded-xl bg-stone-100 dark:bg-stone-800 text-stone-500 hover:text-primary transition-colors relative">
                    <span class="material-symbols-outlined">notifications</span>
                    <span class="absolute top-2.5 right-2.5 size-2 bg-primary rounded-full ring-2 ring-white dark:ring-background-dark"></span>
                </button>
                <div class="h-8 w-px bg-stone-200 dark:bg-stone-800"></div>
                <div class="flex items-center gap-2">
                    <span class="text-sm font-medium text-stone-600 dark:text-stone-400">Library Status</span>
                    <span class="flex items-center gap-1.5 px-2.5 py-1 bg-emerald-100 text-emerald-700 dark:bg-emerald-900/30 dark:text-emerald-400 rounded-full text-xs font-bold uppercase tracking-wider">
                        <span class="size-1.5 bg-emerald-500 rounded-full"></span> Open
                    </span>
                </div>
            </div>
        </header>

        <div class="p-8 space-y-6">
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
                <div class="bg-white dark:bg-stone-900 border border-stone-200 dark:border-stone-800 rounded-xl p-6 shadow-sm">
                    <div class="flex items-center justify-between mb-4">
                        <span class="material-symbols-outlined text-primary text-3xl">group</span>
                        <span class="text-xs font-bold text-emerald-600 bg-emerald-100 px-2 py-1 rounded-full">+12%</span>
                    </div>
                    <p class="text-2xl font-bold text-slate-900 dark:text-slate-100"><%= stats.totalUsers %></p>
                    <p class="text-xs font-semibold text-stone-500 uppercase tracking-wider">Total Users</p>
                </div>
                <div class="bg-white dark:bg-stone-900 border border-stone-200 dark:border-stone-800 rounded-xl p-6 shadow-sm">
                    <div class="flex items-center justify-between mb-4">
                        <span class="material-symbols-outlined text-emerald-600 text-3xl">check_circle</span>
                        <span class="text-xs font-bold text-emerald-600 bg-emerald-100 px-2 py-1 rounded-full">Active</span>
                    </div>
                    <p class="text-2xl font-bold text-slate-900 dark:text-slate-100"><%= stats.activeUsers %></p>
                    <p class="text-xs font-semibold text-stone-500 uppercase tracking-wider">Active Users</p>
                </div>
                <div class="bg-white dark:bg-stone-900 border border-stone-200 dark:border-stone-800 rounded-xl p-6 shadow-sm">
                    <div class="flex items-center justify-between mb-4">
                        <span class="material-symbols-outlined text-red-600 text-3xl">block</span>
                        <span class="text-xs font-bold text-red-600 bg-red-100 px-2 py-1 rounded-full">Blocked</span>
                    </div>
                    <p class="text-2xl font-bold text-slate-900 dark:text-slate-100"><%= stats.blockedUsers %></p>
                    <p class="text-xs font-semibold text-stone-500 uppercase tracking-wider">Blocked Users</p>
                </div>
                <div class="bg-white dark:bg-stone-900 border border-stone-200 dark:border-stone-800 rounded-xl p-6 shadow-sm">
                    <div class="flex items-center justify-between mb-4">
                        <span class="material-symbols-outlined text-blue-600 text-3xl">person_add</span>
                        <span class="text-xs font-bold text-blue-600 bg-blue-100 px-2 py-1 rounded-full">Today</span>
                    </div>
                    <p class="text-2xl font-bold text-slate-900 dark:text-slate-100"><%= stats.newUsersToday %></p>
                    <p class="text-xs font-semibold text-stone-500 uppercase tracking-wider">New Signups</p>
                </div>
            </div>

            <div class="bg-white dark:bg-stone-900 border border-stone-200 dark:border-stone-800 rounded-xl p-6 shadow-sm">
                <h3 class="text-lg font-bold mb-4">Quick Actions</h3>
                <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                    <a href="/admin/users" class="flex items-center gap-3 p-4 border border-stone-200 dark:border-stone-800 rounded-lg hover:bg-stone-50 dark:hover:bg-stone-800 transition-colors">
                        <span class="material-symbols-outlined text-primary text-2xl">group</span>
                        <div>
                            <p class="font-semibold text-sm">Manage Users</p>
                            <p class="text-xs text-stone-500">View and manage all users</p>
                        </div>
                    </a>
                    <a href="/admin/settings" class="flex items-center gap-3 p-4 border border-stone-200 dark:border-stone-800 rounded-lg hover:bg-stone-50 dark:hover:bg-stone-800 transition-colors">
                        <span class="material-symbols-outlined text-primary text-2xl">settings</span>
                        <div>
                            <p class="font-semibold text-sm">Settings</p>
                            <p class="text-xs text-stone-500">Configure system settings</p>
                        </div>
                    </a>
                    <a href="/admin/reports" class="flex items-center gap-3 p-4 border border-stone-200 dark:border-stone-800 rounded-lg hover:bg-stone-50 dark:hover:bg-stone-800 transition-colors">
                        <span class="material-symbols-outlined text-primary text-2xl">bar_chart</span>
                        <div>
                            <p class="font-semibold text-sm">Reports</p>
                            <p class="text-xs text-stone-500">View analytics and reports</p>
                        </div>
                    </a>
                </div>
            </div>
        </div>

        <footer class="mt-auto py-10 border-t border-stone-200 dark:border-stone-800">
            <div class="flex flex-col items-center justify-center text-center space-y-4">
                <p class="text-stone-500 italic font-serif text-lg max-w-2xl">"I have always imagined that Paradise will be a kind of library."</p>
                <div class="flex items-center gap-4 text-xs font-bold uppercase tracking-widest text-stone-400">
                    <span>Jorge Luis Borges</span>
                    <span class="size-1 bg-stone-300 rounded-full"></span>
                    <span>© 2024 Pappyrus Admin Portal</span>
                </div>
            </div>
        </footer>
    </main>
</div>
</body>
</html>
