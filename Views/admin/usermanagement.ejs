<script>
function viewUserDetails(userId) {
    window.location.href = `/admin/users/${userId}`;
}

async function toggleUserStatus(userId, isActive) {
    try {
        const response = await fetch('/admin/users/block-unblock', {
            method: 'POST',
            headers: { 
                'Content-Type': 'application/json',
                'X-Requested-With': 'XMLHttpRequest'
            },
            body: JSON.stringify({ userId: userId })
        });

        if (!response.ok) {
            throw new Error(`HTTP error! status: ${response.status}`);
        }

        const data = await response.json();
        
        if (data.success) {
            const message = data.data.isBlocked ? 'User blocked successfully' : 'User unblocked successfully';
            const icon = data.data.isBlocked ? 'warning' : 'success';
            
            await Swal.fire({
                title: 'Success!',
                text: message,
                icon: icon,
                confirmButtonText: 'OK',
                confirmButtonColor: '#8B4513'
            });
            
            const toggle = document.getElementById(`toggle-${userId}`);
            const statusText = toggle.parentElement.querySelector('span');
            toggle.checked = !data.data.isBlocked;
            statusText.textContent = data.data.isBlocked ? 'Blocked' : 'Active';
            
        } else {
            throw new Error(data.message || 'Action failed');
        }
    } catch (error) {
        const toggle = document.getElementById(`toggle-${userId}`);
        toggle.checked = !toggle.checked;
        
        await Swal.fire({
            title: 'Error!',
            text: 'An error occurred: ' + error.message,
            icon: 'error',
            confirmButtonText: 'OK',
            confirmButtonColor: '#8B4513'
        });
    }
}

history.pushState(null, null, location.href);
window.onpopstate = function () {
    history.go(1);
};

window.addEventListener('beforeunload', function() {
    history.replaceState(null, null, location.href);
});
</script>
