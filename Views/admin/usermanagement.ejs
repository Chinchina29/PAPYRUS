<%- include('../partials/admin-header', { pageTitle: 'User Management' }) %>

<%- include('../partials/admin-sidebar', { currentPage: 'users' }) %>

    <!-- Main Content -->
    <main class="flex-1 ml-0">
        <!-- Header -->
        <header class="bg-white shadow-sm border-b px-6 py-4">
            <div class="flex items-center justify-between">
                <div class="flex items-center gap-6">
                    <form method="GET" action="/admin/users" class="relative">
                        <i class="fas fa-search absolute left-3 top-1/2 transform -translate-y-1/2 text-gray-400"></i>
                        <input name="search" value="<%= search %>" class="pl-10 pr-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-orange-accent focus:border-transparent" placeholder="Search users..." type="text"/>
                    </form>
                </div>
                <div class="flex items-center gap-4">
                    <div class="relative">
                        <i class="fas fa-bell text-gray-400 text-xl cursor-pointer hover:text-gray-600"></i>
                        <span class="absolute -top-1 -right-1 w-3 h-3 bg-red-500 rounded-full"></span>
                    </div>
                    <div class="text-right">
                        <p class="text-sm font-medium text-gray-800">Admin Panel</p>
                        <p class="text-xs text-gray-500">
                            <% if (user && user.firstName && user.lastName) { %>
                                <%= user.firstName %> <%= user.lastName %>
                            <% } else { %>
                                AA
                            <% } %>
                        </p>
                    </div>
                </div>
            </div>
        </header>

        <!-- User Management Content -->
        <div class="p-6">
            <div class="mb-6">
                <h2 class="text-2xl font-bold text-gray-800 mb-2">User Management</h2>
                <div class="flex items-center justify-between">
                    <p class="text-gray-600">Review and manage registered members of the platform</p>
                    <% if (search || status) { %>
                    <div class="flex items-center gap-2 text-sm">
                        <span class="text-gray-500">Active filters:</span>
                        <% if (search) { %>
                        <span class="bg-blue-100 text-blue-800 px-2 py-1 rounded-full">
                            Search: "<%= search %>"
                        </span>
                        <% } %>
                        <% if (status) { %>
                        <span class="bg-<%= status === 'active' ? 'green' : 'red' %>-100 text-<%= status === 'active' ? 'green' : 'red' %>-800 px-2 py-1 rounded-full">
                            Status: <%= status.charAt(0).toUpperCase() + status.slice(1) %>
                        </span>
                        <% } %>
                    </div>
                    <% } %>
                </div>
            </div>

            <!-- Filters -->
            <div class="bg-white rounded-lg shadow-sm p-4 mb-6">
                <form method="GET" action="/admin/users" class="flex items-center gap-4">
                    <div class="relative flex-1 max-w-md">
                        <i class="fas fa-search absolute left-3 top-1/2 transform -translate-y-1/2 text-gray-400"></i>
                        <input name="search" value="<%= search %>" class="w-full pl-10 pr-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-orange-accent focus:border-transparent" placeholder="Search by name..." type="text"/>
                    </div>
                    <div class="flex items-center gap-2">
                        <label class="text-sm font-medium text-gray-700">Role:</label>
                        <select name="role" class="border border-gray-300 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-orange-accent">
                            <option value="">All Roles</option>
                            <option value="buyer">Buyer</option>
                            <option value="seller">Seller</option>
                        </select>
                    </div>
                    <div class="flex items-center gap-2">
                        <label class="text-sm font-medium text-gray-700">Status:</label>
                        <select name="status" class="border border-gray-300 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-orange-accent">
                            <option value="" <%= status === '' ? 'selected' : '' %>>All Status</option>
                            <option value="active" <%= status === 'active' ? 'selected' : '' %>>Active</option>
                            <option value="blocked" <%= status === 'blocked' ? 'selected' : '' %>>Blocked</option>
                        </select>
                    </div>
                    <button type="submit" class="bg-warm-brown text-white px-4 py-2 rounded-lg hover:bg-dark-brown transition-colors">
                        <i class="fas fa-filter mr-2"></i>Filter
                    </button>
                    <% if (search || status) { %>
                    <a href="/admin/users" class="bg-gray-500 text-white px-4 py-2 rounded-lg hover:bg-gray-600 transition-colors">
                        <i class="fas fa-times mr-2"></i>Clear
                    </a>
                    <% } %>
                </form>
            </div>

            <!-- Users Table -->
            <div class="bg-white rounded-lg shadow-sm overflow-hidden">
                <table class="w-full">
                    <thead class="bg-gray-50 border-b border-gray-200">
                        <tr>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">User Name</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Email</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Role</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Joined Date</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Action</th>
                        </tr>
                    </thead>
                    <tbody class="bg-white divide-y divide-gray-200">
                        <% users.forEach(user => { %>
                        <tr class="hover:bg-gray-50">
                            <td class="px-6 py-4 whitespace-nowrap">
                                <div class="text-sm font-medium text-gray-900"><%= user.firstName %> <%= user.lastName %></div>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap">
                                <div class="text-sm text-gray-900"><%= user.email %></div>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap">
                                <div class="text-sm text-gray-900 capitalize">
                                    <% if (user.role === 'user') { %>
                                        Buyer
                                    <% } else { %>
                                        <%= user.role %>
                                    <% } %>
                                </div>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap">
                                <div class="text-sm text-gray-900">
                                    <%= new Date(user.createdAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %>
                                </div>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap">
                                <div class="flex items-center">
                                    <label class="relative inline-flex items-center cursor-pointer">
                                        <input type="checkbox" 
                                               id="toggle-<%= user._id %>" 
                                               class="sr-only peer"
                                               <%= user.isBlocked ? '' : 'checked' %>
                                               onchange="toggleUserStatus('<%= user._id %>', this.checked)"/>
                                        <div class="relative w-11 h-6 bg-gray-200 peer-focus:outline-none peer-focus:ring-4 peer-focus:ring-blue-300 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-green-500"></div>
                                        <span class="ml-3 text-sm font-medium text-gray-900">
                                            <%= user.isBlocked ? 'Blocked' : 'Active' %>
                                        </span>
                                    </label>
                                </div>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap">
                                <button class="bg-warm-brown text-white px-4 py-2 rounded-lg text-sm hover:bg-dark-brown transition-colors">
                                    View Details
                                </button>
                            </td>
                        </tr>
                        <% }); %>
                    </tbody>
                </table>
            </div>

            <!-- Pagination -->
            <div class="mt-6 flex items-center justify-between">
                <div class="text-sm text-gray-700">
                    Page <%= currentPage %> of <%= totalPages %> 
                    <% if (search || status) { %>
                        <span class="text-gray-500">
                            (filtered: <%= total %> users)
                        </span>
                    <% } else { %>
                        (<%= total %> total users)
                    <% } %>
                </div>
                <div class="flex items-center gap-2">
                    <% 
                        const buildUrl = (page) => {
                            let url = `?page=${page}`;
                            if (search) url += `&search=${encodeURIComponent(search)}`;
                            if (status) url += `&status=${status}`;
                            return url;
                        }
                    %>
                    
                    <button class="px-3 py-1 text-sm text-gray-500 hover:text-gray-700 <%= currentPage === 1 ? 'opacity-50 cursor-not-allowed' : '' %>"
                            <%= currentPage === 1 ? 'disabled' : '' %>
                            <% if (currentPage > 1) { %>onclick="window.location.href='<%= buildUrl(currentPage - 1) %>'"<% } %>>
                        PREVIOUS
                    </button>
                    
                    <% for (let i = 1; i <= Math.min(totalPages, 5); i++) { %>
                    <button class="w-8 h-8 text-sm rounded <%= currentPage === i ? 'bg-warm-brown text-white' : 'text-gray-700 hover:bg-gray-100' %>"
                            onclick="window.location.href='<%= buildUrl(i) %>'">
                        <%= i %>
                    </button>
                    <% } %>
                    
                    <button class="px-3 py-1 text-sm text-gray-500 hover:text-gray-700 <%= currentPage === totalPages ? 'opacity-50 cursor-not-allowed' : '' %>"
                            <%= currentPage === totalPages ? 'disabled' : '' %>
                            <% if (currentPage < totalPages) { %>onclick="window.location.href='<%= buildUrl(currentPage + 1) %>'"<% } %>>
                        NEXT
                    </button>
                </div>
            </div>
        </div>
    </main>
</div>



<script>
async function toggleUserStatus(userId, isActive) {
    try {
        console.log('Toggling user status for:', userId, 'Active:', isActive);
        
        const response = await fetch('/admin/users/block-unblock', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ userId: userId })
        });

        const data = await response.json();
        console.log('Response:', data);
        
        if (data.success) {
            const message = data.data.isBlocked ? 'User blocked successfully' : 'User unblocked successfully';
            const icon = data.data.isBlocked ? 'warning' : 'success';
            
            Swal.fire({
                title: 'Success!',
                text: message,
                icon: icon,
                confirmButtonText: 'OK',
                confirmButtonColor: '#8B4513'
            }).then(() => {
                location.reload();
            });
        } else {
            Swal.fire({
                title: 'Error!',
                text: data.message || 'Action failed',
                icon: 'error',
                confirmButtonText: 'OK',
                confirmButtonColor: '#8B4513'
            }).then(() => {
                location.reload();
            });
        }
    } catch (error) {
        console.error('Error:', error);
        Swal.fire({
            title: 'Error!',
            text: 'An error occurred: ' + error.message,
            icon: 'error',
            confirmButtonText: 'OK',
            confirmButtonColor: '#8B4513'
        }).then(() => {
            location.reload();
        });
    }
}
</script>
</body>
</html>