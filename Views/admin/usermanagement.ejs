<%- include('../partials/admin-header', { pageTitle: 'User Management' }) %>

<%- include('../partials/admin-sidebar', { currentPage: 'users' }) %>

<div class="main-content">
    <!-- Top Header -->
    <div class="top-header">
        <div class="search-bar">
            <input type="text" class="search-input" placeholder="Search users by name or email...">
        </div>
        
        <div class="header-actions">
            <button class="notification-btn">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M6 8a6 6 0 0 1 12 0c0 7 3 9 3 9H3s3-2 3-9"/>
                    <path d="M13.73 21a2 2 0 0 1-3.46 0"/>
                </svg>
            </button>
            
            <div class="admin-info">
                <div class="admin-panel-text">Admin Panel</div>
                <div class="admin-name"><%= user?.firstName || 'Admin' %> <%= user?.lastName || 'User' %></div>
            </div>
        </div>
    </div>

    <!-- User Management Content -->
    <div class="user-management-content">
        <!-- Page Header -->
        <div class="page-header">
            <div class="page-title">
                <h1>User Management</h1>
                <p>Review and manage registered members of the platform</p>
            </div>
            
            <div class="page-actions">
                <% if (search || status) { %>
                <div class="active-filters">
                    <span class="filter-label">Active filters:</span>
                    <% if (search) { %>
                    <span class="filter-tag search-filter">
                        Search: "<%= search %>"
                    </span>
                    <% } %>
                    <% if (status) { %>
                    <span class="filter-tag status-filter <%= status %>">
                        Status: <%= status.charAt(0).toUpperCase() + status.slice(1) %>
                    </span>
                    <% } %>
                </div>
                <% } %>
                
                <button class="export-btn">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
                        <polyline points="7,10 12,15 17,10"/>
                        <line x1="12" y1="15" x2="12" y2="3"/>
                    </svg>
                    Export Users
                </button>
            </div>
        </div>

        <!-- Filter Section -->
        <div class="filter-section">
            <form method="GET" action="/admin/users" class="filter-form">
                <div class="filter-group">
                    <div class="search-filter">
                        <svg class="filter-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <circle cx="11" cy="11" r="8"/>
                            <path d="m21 21-4.35-4.35"/>
                        </svg>
                        <input name="search" value="<%= search %>" class="filter-input" placeholder="Search by name or email..." type="text"/>
                    </div>
                    
                    <div class="select-filter">
                        <label class="filter-label">Role:</label>
                        <select name="role" class="filter-select">
                            <option value="">All Roles</option>
                            <option value="buyer">Buyer</option>
                            <option value="seller">Seller</option>
                        </select>
                    </div>
                    
                    <div class="select-filter">
                        <label class="filter-label">Status:</label>
                        <select name="status" class="filter-select">
                            <option value="" <%= status === '' ? 'selected' : '' %>>All Status</option>
                            <option value="active" <%= status === 'active' ? 'selected' : '' %>>Active</option>
                            <option value="blocked" <%= status === 'blocked' ? 'selected' : '' %>>Blocked</option>
                        </select>
                    </div>
                </div>
                
                <div class="filter-actions">
                    <button type="submit" class="filter-btn">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M8 6h13"/>
                            <path d="M6 12h9"/>
                            <path d="M4 18h7"/>
                        </svg>
                        Filter
                    </button>
                    <% if (search || status) { %>
                    <a href="/admin/users" class="clear-btn">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <line x1="18" y1="6" x2="6" y2="18"/>
                            <line x1="6" y1="6" x2="18" y2="18"/>
                        </svg>
                        Clear
                    </a>
                    <% } %>
                </div>
            </form>
        </div>

        <!-- Users Table -->
        <div class="users-table-container">
            <div class="table-header">
                <div class="header-cell">User</div>
                <div class="header-cell">Email</div>
                <div class="header-cell">Role</div>
                <div class="header-cell">Joined Date</div>
                <div class="header-cell">Status</div>
                <div class="header-cell">Actions</div>
            </div>

            <div class="table-body">
                <% users.forEach(user => { %>
                <div class="table-row">
                    <div class="table-cell user-cell">
                        <div class="user-avatar">
                            <% if (user.profilePicture) { %>
                                <img src="<%= user.profilePicture %>" alt="<%= user.firstName %>" />
                            <% } else { %>
                                <span><%= user.firstName?.charAt(0) || 'U' %><%= user.lastName?.charAt(0) || 'U' %></span>
                            <% } %>
                        </div>
                        <div class="user-info">
                            <div class="user-name"><%= user.firstName %> <%= user.lastName %></div>
                            <div class="user-id">ID: <%= user._id.toString().slice(-8) %></div>
                        </div>
                    </div>
                    
                    <div class="table-cell email-cell">
                        <div class="email-text"><%= user.email %></div>
                        <% if (user.isVerified) { %>
                        <div class="verified-badge">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <polyline points="20,6 9,17 4,12"/>
                            </svg>
                            Verified
                        </div>
                        <% } %>
                    </div>
                    
                    <div class="table-cell role-cell">
                        <span class="role-badge <%= user.role %>">
                            <% if (user.role === 'user') { %>
                                Buyer
                            <% } else { %>
                                <%= user.role.charAt(0).toUpperCase() + user.role.slice(1) %>
                            <% } %>
                        </span>
                    </div>
                    
                    <div class="table-cell date-cell">
                        <div class="date-text">
                            <%= new Date(user.createdAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %>
                        </div>
                        <div class="time-text">
                            <%= new Date(user.createdAt).toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit' }) %>
                        </div>
                    </div>
                    
                    <div class="table-cell status-cell">
                        <label class="status-toggle">
                            <input type="checkbox" 
                                   id="toggle-<%= user._id %>" 
                                   class="toggle-input"
                                   <%= user.isBlocked ? '' : 'checked' %>
                                   onchange="toggleUserStatus('<%= user._id %>', this.checked)"/>
                            <div class="toggle-slider"></div>
                            <span class="status-text">
                                <%= user.isBlocked ? 'Blocked' : 'Active' %>
                            </span>
                        </label>
                    </div>
                    
                    <div class="table-cell actions-cell">
                        <button class="action-btn view-btn" onclick="viewUserDetails('<%= user._id %>')">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                                <circle cx="12" cy="12" r="3"/>
                            </svg>
                            View Details
                        </button>
                    </div>
                </div>
                <% }); %>
            </div>
        </div>

        <!-- Pagination -->
        <div class="pagination-section">
            <div class="pagination-info">
                <span class="page-text">Page <%= currentPage %> of <%= totalPages %></span>
                <% if (search || status) { %>
                    <span class="total-text">(filtered: <%= total %> users)</span>
                <% } else { %>
                    <span class="total-text">(<%= total %> total users)</span>
                <% } %>
            </div>
            
            <div class="pagination-controls">
                <% 
                    const buildUrl = (page) => {
                        let url = `?page=${page}`;
                        if (search) url += `&search=${encodeURIComponent(search)}`;
                        if (status) url += `&status=${status}`;
                        return url;
                    }
                %>
                
                <button class="pagination-btn <%= currentPage === 1 ? 'disabled' : '' %>"
                        <%= currentPage === 1 ? 'disabled' : '' %>
                        <% if (currentPage > 1) { %>onclick="window.location.href='<%= buildUrl(currentPage - 1) %>'"<% } %>>
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <polyline points="15,18 9,12 15,6"/>
                    </svg>
                    Previous
                </button>
                
                <div class="page-numbers">
                    <% for (let i = 1; i <= Math.min(totalPages, 5); i++) { %>
                    <button class="page-number <%= currentPage === i ? 'active' : '' %>"
                            onclick="window.location.href='<%= buildUrl(i) %>'">
                        <%= i %>
                    </button>
                    <% } %>
                </div>
                
                <button class="pagination-btn <%= currentPage === totalPages ? 'disabled' : '' %>"
                        <%= currentPage === totalPages ? 'disabled' : '' %>
                        <% if (currentPage < totalPages) { %>onclick="window.location.href='<%= buildUrl(currentPage + 1) %>'"<% } %>>
                    Next
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <polyline points="9,18 15,12 9,6"/>
                    </svg>
                </button>
            </div>
        </div>
    </div>
</div>

