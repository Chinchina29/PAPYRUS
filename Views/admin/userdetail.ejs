<%- include('../partials/admin-header', { pageTitle: 'User Details' }) %>

<%- include('../partials/admin-sidebar', { currentPage: 'users' }) %>

<div class="main-content">
    <!-- Top Header -->
    <div class="top-header">
        <div class="search-bar">
            <input type="text" class="search-input" placeholder="Search for books, authors...">
        </div>
        
        <div class="header-actions">
            <button class="notification-btn">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M6 8a6 6 0 0 1 12 0c0 7 3 9 3 9H3s3-2 3-9"/>
                    <path d="M13.73 21a2 2 0 0 1-3.46 0"/>
                </svg>
            </button>
            
            <div class="admin-info">
                <div class="admin-panel-text">Admin Panel</div>
                <div class="admin-name"><%= adminUser?.firstName || 'Admin' %> <%= adminUser?.lastName || 'User' %></div>
            </div>
        </div>
    </div>

    <!-- User Detail Content -->
    <div class="user-detail-content">
        <!-- Breadcrumb -->
        <div class="breadcrumb">
            <a href="/admin/users" class="breadcrumb-link">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <polyline points="15,18 9,12 15,6"/>
                </svg>
                Back to User Management
            </a>
        </div>

        <!-- User Profile Card -->
        <div class="user-profile-card">
            <div class="profile-header">
                <div class="user-avatar-large">
                    <% if (user.profilePicture) { %>
                        <img src="<%= user.profilePicture %>" alt="<%= user.firstName %>" />
                    <% } else { %>
                        <span><%= user.firstName?.charAt(0) || 'U' %><%= user.lastName?.charAt(0) || 'U' %></span>
                    <% } %>
                </div>
                
                <div class="user-main-info">
                    <h1 class="user-full-name"><%= user.firstName %> <%= user.lastName %></h1>
                    <div class="user-role-badge">
                        <span class="role-text">
                            <% if (user.role === 'user') { %>
                                Seller
                            <% } else { %>
                                <%= user.role.charAt(0).toUpperCase() + user.role.slice(1) %>
                            <% } %>
                        </span>
                        <span class="join-date">Member since <%= new Date(user.createdAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %></span>
                    </div>
                </div>
                
                <div class="profile-actions">
                    <button class="action-btn block-user-btn <%= user.isBlocked ? 'unblock' : 'block' %>" 
                            onclick="toggleUserStatus('<%= user._id %>', <%= !user.isBlocked %>)">
                        <% if (user.isBlocked) { %>
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                                <circle cx="12" cy="12" r="3"/>
                            </svg>
                            Unblock User
                        <% } else { %>
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <circle cx="12" cy="12" r="10"/>
                                <line x1="4.93" y1="4.93" x2="19.07" y2="19.07"/>
                            </svg>
                            Block User
                        <% } %>
                    </button>
                </div>
            </div>
            
            <!-- User Details Grid -->
            <div class="user-details-grid">
                <div class="detail-item">
                    <div class="detail-label">Email Address</div>
                    <div class="detail-value">
                        <%= user.email %>
                        <% if (user.isVerified) { %>
                            <span class="verified-badge">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <polyline points="20,6 9,17 4,12"/>
                                </svg>
                                Verified
                            </span>
                        <% } %>
                    </div>
                </div>
                
                <div class="detail-item">
                    <div class="detail-label">Phone Number</div>
                    <div class="detail-value"><%= user.phone || 'Not provided' %></div>
                </div>
                
                <div class="detail-item">
                    <div class="detail-label">Total Books Sold</div>
                    <div class="detail-value">14 Volumes</div>
                </div>
            </div>
        </div>

        <!-- Sold Books Section -->
        <div class="sold-books-section">
            <div class="section-header">
                <h2>Sold Books</h2>
                <p>Showing 4 most recent sales</p>
            </div>
            
            <div class="books-grid">
                <div class="book-card">
                    <div class="book-cover green">
                        <div class="book-spine">
                            <div class="book-title">Book Cover</div>
                            <div class="book-subtitle">Design Basics</div>
                            <div class="book-author">Elizabeth Gonzalez</div>
                        </div>
                    </div>
                    <div class="book-info">
                        <h3 class="book-name">Moby Dick</h3>
                        <div class="book-price">$45.00</div>
                        <div class="book-date">Sold Dec 17, 2023</div>
                    </div>
                </div>
                
                <div class="book-card">
                    <div class="book-cover white">
                        <div class="book-content">
                            <div class="book-title-page">
                                <div class="title-text">POPULAR SCIENCE</div>
                                <div class="subtitle-text">MONTHLY</div>
                                <div class="author-text">WRITTEN BY SCIENTISTS</div>
                            </div>
                        </div>
                    </div>
                    <div class="book-info">
                        <h3 class="book-name">The Old Man and the Sea</h3>
                        <div class="book-price">$32.50</div>
                        <div class="book-date">Sold Dec 15, 2023</div>
                    </div>
                </div>
                
                <div class="book-card">
                    <div class="book-cover beige">
                        <div class="book-content">
                            <div class="book-title-simple">ANIMAL</div>
                            <div class="book-subtitle-simple">BOOK COVER</div>
                        </div>
                    </div>
                    <div class="book-info">
                        <h3 class="book-name">Treasure Island</h3>
                        <div class="book-price">$28.00</div>
                        <div class="book-date">Sold Dec 10, 2023</div>
                    </div>
                </div>
                
                <div class="book-card">
                    <div class="book-cover teal">
                        <div class="book-content">
                            <div class="book-title-elegant">SHAKESPEARE</div>
                            <div class="book-subtitle-elegant">COMPLETE WORKS</div>
                        </div>
                    </div>
                    <div class="book-info">
                        <h3 class="book-name">Robinson Crusoe</h3>
                        <div class="book-price">$38.00</div>
                        <div class="book-date">Sold Dec 8, 2023</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
.user-detail-content {
    padding: 32px;
}

.breadcrumb {
    margin-bottom: 24px;
}

.breadcrumb-link {
    display: flex;
    align-items: center;
    gap: 8px;
    color: #8b7355;
    text-decoration: none;
    font-size: 14px;
    font-weight: 500;
    transition: all 0.2s ease;
}

.breadcrumb-link:hover {
    color: #5a4a3a;
}

.breadcrumb-link svg {
    width: 16px;
    height: 16px;
}

.user-profile-card {
    background: white;
    border-radius: 12px;
    padding: 32px;
    margin-bottom: 32px;
    border: 1px solid #e8dcc8;
}

.profile-header {
    display: flex;
    align-items: flex-start;
    gap: 24px;
    margin-bottom: 32px;
}

.user-avatar-large {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    background: #8b7355;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-weight: 600;
    font-size: 28px;
    flex-shrink: 0;
    overflow: hidden;
}

.user-avatar-large img {
    width: 100%;
    height: 100%;
    object-fit: cover;
}

.user-main-info {
    flex: 1;
}

.user-full-name {
    font-size: 32px;
    font-weight: 600;
    color: #3a3a3a;
    margin-bottom: 8px;
}

.user-role-badge {
    display: flex;
    flex-direction: column;
    gap: 4px;
}

.role-text {
    padding: 6px 16px;
    background: #e3f2fd;
    color: #1565c0;
    border-radius: 20px;
    font-size: 14px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    display: inline-block;
    width: fit-content;
}

.join-date {
    font-size: 14px;
    color: #5a4d42;
}

.profile-actions {
    display: flex;
    justify-content: center;
}

.action-btn {
    padding: 12px 20px;
    border-radius: 8px;
    font-size: 14px;
    font-weight: 500;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 8px;
    transition: all 0.2s ease;
    border: 1px solid;
    white-space: nowrap;
}

.block-user-btn.block {
    background: #dc3545;
    color: white;
    border-color: #dc3545;
}

.block-user-btn.block:hover {
    background: #c82333;
    border-color: #c82333;
}

.block-user-btn.unblock {
    background: #28a745;
    color: white;
    border-color: #28a745;
}

.block-user-btn.unblock:hover {
    background: #218838;
    border-color: #218838;
}

.action-btn svg {
    width: 16px;
    height: 16px;
}

.user-details-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
}

.detail-item {
    display: flex;
    flex-direction: column;
    gap: 8px;
}

.detail-label {
    font-size: 12px;
    font-weight: 600;
    color: #5a4d42;
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

.detail-value {
    font-size: 16px;
    font-weight: 500;
    color: #3a3a3a;
    display: flex;
    align-items: center;
    gap: 8px;
}

.verified-badge {
    display: flex;
    align-items: center;
    gap: 4px;
    font-size: 12px;
    color: #2e7d32;
    font-weight: 500;
}

.verified-badge svg {
    width: 14px;
    height: 14px;
}

.sold-books-section {
    background: white;
    border-radius: 12px;
    padding: 32px;
    border: 1px solid #e8dcc8;
}

.section-header {
    margin-bottom: 24px;
}

.section-header h2 {
    font-size: 24px;
    font-weight: 600;
    color: #3a3a3a;
    margin-bottom: 4px;
}

.section-header p {
    font-size: 14px;
    color: #5a4d42;
}

.books-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
}

.book-card {
    display: flex;
    flex-direction: column;
    gap: 16px;
}

.book-cover {
    width: 100%;
    height: 200px;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
}

.book-cover.green {
    background: #2d5a3d;
    color: white;
}

.book-cover.white {
    background: #f8f8f8;
    color: #333;
    border: 1px solid #e0e0e0;
}

.book-cover.beige {
    background: #f5f1ed;
    color: #8b7355;
}

.book-cover.teal {
    background: #4a9b8e;
    color: white;
}

.book-spine {
    text-align: center;
    padding: 20px;
}

.book-title {
    font-size: 14px;
    font-weight: 600;
    margin-bottom: 8px;
}

.book-subtitle {
    font-size: 12px;
    margin-bottom: 16px;
}

.book-author {
    font-size: 10px;
    opacity: 0.8;
}

.book-content {
    text-align: center;
    padding: 20px;
}

.book-title-page {
    display: flex;
    flex-direction: column;
    gap: 8px;
}

.title-text {
    font-size: 16px;
    font-weight: 700;
}

.subtitle-text {
    font-size: 14px;
    font-weight: 600;
}

.author-text {
    font-size: 10px;
    margin-top: 16px;
}

.book-title-simple {
    font-size: 18px;
    font-weight: 700;
    margin-bottom: 8px;
}

.book-subtitle-simple {
    font-size: 12px;
    font-weight: 500;
}

.book-title-elegant {
    font-size: 16px;
    font-weight: 600;
    margin-bottom: 8px;
}

.book-subtitle-elegant {
    font-size: 12px;
    font-weight: 400;
}

.book-info {
    text-align: center;
}

.book-name {
    font-size: 16px;
    font-weight: 600;
    color: #3a3a3a;
    margin-bottom: 4px;
}

.book-price {
    font-size: 18px;
    font-weight: 700;
    color: #8b7355;
    margin-bottom: 4px;
}

.book-date {
    font-size: 12px;
    color: #5a4d42;
}

@media (max-width: 1200px) {
    .books-grid {
        grid-template-columns: repeat(3, 1fr);
    }
    
    .user-details-grid {
        grid-template-columns: repeat(2, 1fr);
    }
}

@media (max-width: 768px) {
    .user-detail-content {
        padding: 16px;
    }
    
    .profile-header {
        flex-direction: column;
        align-items: center;
        text-align: center;
    }
    
    .profile-actions {
        flex-direction: row;
        justify-content: center;
    }
    
    .user-details-grid {
        grid-template-columns: 1fr;
        gap: 16px;
    }
    
    .books-grid {
        grid-template-columns: repeat(2, 1fr);
    }
    
    .user-full-name {
        font-size: 24px;
    }
}

@media (max-width: 480px) {
    .books-grid {
        grid-template-columns: 1fr;
    }
}
</style>

<script>
async function toggleUserStatus(userId, isActive) {
    try {
        const response = await fetch('/admin/users/block-unblock', {
            method: 'POST',
            headers: { 
                'Content-Type': 'application/json',
                'X-Requested-With': 'XMLHttpRequest'
            },
            body: JSON.stringify({ userId: userId })
        });

        if (!response.ok) {
            throw new Error(`HTTP error! status: ${response.status}`);
        }

        const data = await response.json();
        
        if (data.success) {
            const message = data.data.isBlocked ? 'User blocked successfully' : 'User unblocked successfully';
            const icon = data.data.isBlocked ? 'warning' : 'success';
            
            await Swal.fire({
                title: 'Success!',
                text: message,
                icon: icon,
                confirmButtonText: 'OK',
                confirmButtonColor: '#8B4513'
            });
            
            // Reload the page to update the UI
            window.location.reload();
            
        } else {
            throw new Error(data.message || 'Action failed');
        }
    } catch (error) {
        await Swal.fire({
            title: 'Error!',
            text: 'An error occurred: ' + error.message,
            icon: 'error',
            confirmButtonText: 'OK',
            confirmButtonColor: '#8B4513'
        });
    }
}

history.pushState(null, null, location.href);
window.onpopstate = function () {
    history.go(1);
};

window.addEventListener('beforeunload', function() {
    history.replaceState(null, null, location.href);
});
</script>
</body>
</html>