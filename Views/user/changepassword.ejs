<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta content="width=device-width, initial-scale=1.0" name="viewport"/>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <link href="https://fonts.googleapis.com/css2?family=Public+Sans:wght@400;500;600;700;900&display=swap" rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols_Outlined:wght@100..700,0..1&display=swap" rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400..900;1,400..900&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet"/>
    <script>
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        primary: "#2D3B2D",
                        secondary: "#5C4B3F",
                        "background-light": "#F5F3ED",
                        "background-dark": "#1A1D1A",
                        accent: "#C2D2BD",
                        "sage-light": "#E9EBE4",
                    },
                    fontFamily: {
                        display: ["Playfair Display", "serif"],
                        sans: ["Inter", "sans-serif"],
                    },
                    borderRadius: {
                        DEFAULT: "4px",
                    },
                },
            },
        };
    </script>
    <title>Pappyrus - Change Password</title>
</head>
<body class="bg-background-light dark:bg-background-dark font-display text-slate-900 dark:text-slate-100">
<div class="relative flex h-screen w-full overflow-hidden">
    <aside class="flex h-full w-64 flex-col bg-primary text-white shrink-0">
        <div class="flex items-center gap-3 px-6 py-8">
            <div class="size-8 text-white">
                <span class="material-symbols-outlined text-3xl">menu_book</span>
            </div>
            <h2 class="text-xl font-bold tracking-tight font-display">Pappyrus</h2>
        </div>
        <div class="flex flex-col gap-1 px-4 grow">
            <a class="flex items-center gap-3 px-4 py-3 text-sm font-bold uppercase tracking-wider text-accent/70 hover:text-white hover:bg-white/10 transition-colors" href="/home">
                <span class="material-symbols-outlined text-xl">home</span>Home
            </a>
            <a class="flex items-center gap-3 px-4 py-3 text-sm font-bold uppercase tracking-wider text-accent/70 hover:text-white hover:bg-white/10 transition-colors" href="/profile">
                <span class="material-symbols-outlined text-xl">person</span>Profile
            </a>
            <a class="flex items-center gap-3 px-4 py-3 text-sm font-bold uppercase tracking-wider bg-white text-primary border-l-4 border-white shadow-sm" href="/profile/change-password">
                <span class="material-symbols-outlined text-xl">security</span>Security
            </a>
        </div>
        <div class="p-4 border-t border-white/10">
            <div class="flex items-center gap-3 px-2 py-2">
                <div class="size-10 rounded-full bg-primary/20 flex items-center justify-center text-white font-bold">
                    <%= user.firstName.charAt(0) %><%= user.lastName.charAt(0) %>
                </div>
                <div class="flex flex-col overflow-hidden">
                    <p class="text-sm font-bold truncate"><%= user.firstName %> <%= user.lastName %></p>
                    <p class="text-xs text-slate-400 truncate"><%= user.email %></p>
                </div>
            </div>
        </div>
    </aside>

    <main class="flex-1 flex flex-col bg-background-light dark:bg-background-dark overflow-y-auto font-sans">
        <header class="flex items-center justify-between px-8 py-4 bg-white dark:bg-background-dark/50 border-b border-slate-200 dark:border-slate-800">
            <div class="flex items-center gap-4">
                <h1 class="text-lg font-bold font-display">Security Settings</h1>
            </div>
            <div class="flex items-center gap-4">
                <a href="/logout" class="p-2 rounded-full hover:bg-slate-100 dark:hover:bg-slate-800 text-slate-600 dark:text-slate-400">
                    <span class="material-symbols-outlined">logout</span>
                </a>
            </div>
        </header>

        <div class="flex-1 p-8 md:p-12 lg:p-16">
            <div class="max-w-2xl mx-auto">
                <div class="mb-10">
                    <h2 class="text-4xl font-display font-bold text-primary dark:text-accent mb-2">Change Password</h2>
                    <p class="text-slate-600 dark:text-slate-400">Update your account credentials to keep your portal secure. We recommend using a mix of letters, numbers, and special characters.</p>
                </div>
                <form id="changePasswordForm" class="space-y-6 bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 p-8 shadow-sm">
                    <div class="flex flex-col gap-2">
                        <label class="text-[10px] font-bold uppercase tracking-widest text-slate-400 mb-1">Current Password</label>
                        <div class="relative flex items-center group">
                            <span class="absolute left-3 text-slate-400 material-symbols-outlined">lock_open</span>
                            <input name="currentPassword" required class="w-full pl-10 pr-12 py-3 rounded-sm border border-slate-200 dark:border-slate-800 bg-transparent focus:ring-1 focus:ring-primary focus:border-primary outline-none text-slate-900 dark:text-slate-100 transition-all text-sm" placeholder="Enter your current password" type="password"/>
                        </div>
                    </div>
                    <hr class="border-slate-100 dark:border-slate-800 my-2"/>
                    <div class="flex flex-col gap-2">
                        <label class="text-[10px] font-bold uppercase tracking-widest text-slate-400 mb-1">New Password</label>
                        <div class="relative flex items-center group">
                            <span class="absolute left-3 text-slate-400 material-symbols-outlined">lock</span>
                            <input name="newPassword" required class="w-full pl-10 pr-12 py-3 rounded-sm border border-slate-200 dark:border-slate-800 bg-transparent focus:ring-1 focus:ring-primary focus:border-primary outline-none text-slate-900 dark:text-slate-100 transition-all text-sm" placeholder="Create a new password" type="password"/>
                        </div>
                    </div>
                    <div class="flex flex-col gap-2">
                        <label class="text-[10px] font-bold uppercase tracking-widest text-slate-400 mb-1">Confirm New Password</label>
                        <div class="relative flex items-center group">
                            <span class="absolute left-3 text-slate-400 material-symbols-outlined">verified_user</span>
                            <input name="confirmPassword" required class="w-full pl-10 pr-12 py-3 rounded-sm border border-slate-200 dark:border-slate-800 bg-transparent focus:ring-1 focus:ring-primary focus:border-primary outline-none text-slate-900 dark:text-slate-100 transition-all text-sm" placeholder="Repeat your new password" type="password"/>
                        </div>
                    </div>
                    <div class="pt-6 flex flex-col sm:flex-row gap-4">
                        <button type="submit" class="flex-1 bg-primary text-white py-4 px-6 flex items-center justify-center gap-3 text-[10px] font-bold uppercase tracking-widest hover:bg-slate-800 transition-all shadow-md active:scale-[0.98]">
                            <span class="material-symbols-outlined">save</span>Update Password
                        </button>
                        <a href="/profile" class="px-8 py-4 border border-slate-200 dark:border-slate-800 text-slate-600 dark:text-slate-400 text-[10px] font-bold uppercase tracking-widest hover:bg-slate-50 dark:hover:bg-slate-800 transition-all text-center">Cancel</a>
                    </div>
                </form>
                <div class="mt-8 p-6 bg-sage-light/30 border border-slate-200 dark:border-slate-800 flex gap-4 items-start">
                    <span class="material-symbols-outlined text-primary mt-0.5">info</span>
                    <div>
                        <p class="text-sm font-bold text-slate-900 dark:text-slate-100 font-display text-lg text-primary mb-1">Need help?</p>
                        <p class="text-sm text-slate-600 dark:text-slate-400">If you've forgotten your current password, please use the forgot password option on the login page.</p>
                    </div>
                </div>
            </div>
        </div>
    </main>
</div>

<script>
    document.getElementById('changePasswordForm').addEventListener('submit', async (e) => {
        e.preventDefault();
        const formData = new FormData(e.target);
        const data = Object.fromEntries(formData);

        if (data.newPassword !== data.confirmPassword) {
            Swal.fire({
                title: 'Password Mismatch',
                text: 'Passwords do not match',
                icon: 'warning',
                confirmButtonText: 'OK',
                confirmButtonColor: '#2D3B2D'
            });
            return;
        }

        try {
            const response = await fetch('/profile/change-password', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            });

            const result = await response.json();
            if (result.success) {
                Swal.fire({
                    title: 'Success!',
                    text: 'Password changed successfully',
                    icon: 'success',
                    confirmButtonText: 'OK',
                    confirmButtonColor: '#2D3B2D'
                }).then(() => {
                    window.location.href = result.redirect || '/profile';
                });
            } else {
                Swal.fire({
                    title: 'Error!',
                    text: result.message || 'Failed to change password',
                    icon: 'error',
                    confirmButtonText: 'OK',
                    confirmButtonColor: '#2D3B2D'
                });
            }
        } catch (error) {
            console.error('Error:', error);
            Swal.fire({
                title: 'Error!',
                text: 'An error occurred',
                icon: 'error',
                confirmButtonText: 'OK',
                confirmButtonColor: '#2D3B2D'
            });
        }
    });
</script>
</body>
</html>
