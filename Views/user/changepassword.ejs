<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Papyrus - Change Password</title>
    <link rel="stylesheet" href="/css/profile.css">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <style>
        .form-group {
            margin-bottom: 20px;
        }
        .form-group label {
            display: block;
            font-size: 11px;
            font-weight: 600;
            color: #999;
            letter-spacing: 1px;
            margin-bottom: 8px;
            text-transform: uppercase;
        }
        .form-group input {
            width: 100%;
            padding: 12px 15px;
            border: 1px solid #e0d5c7;
            border-radius: 4px;
            font-size: 14px;
            color: #3a3a3a;
            background: white;
            transition: border-color 0.3s;
        }
        .form-group input:focus {
            outline: none;
            border-color: #7A5C3E;
        }
        .password-strength {
            height: 4px;
            border-radius: 2px;
            transition: all 0.3s ease;
            background: #e0d5c7;
            margin-top: 8px;
        }
        .strength-indicator {
            height: 100%;
            border-radius: 2px;
            transition: all 0.3s ease;
        }
        .strength-weak .strength-indicator { background: #dc2626; width: 25%; }
        .strength-fair .strength-indicator { background: #d97706; width: 50%; }
        .strength-good .strength-indicator { background: #8b7355; width: 75%; }
        .strength-strong .strength-indicator { background: #5a4a3a; width: 100%; }
        .btn-secondary {
            padding: 12px 30px;
            background: transparent;
            color: #666;
            border: 1px solid #e0d5c7;
            border-radius: 4px;
            font-size: 12px;
            font-weight: 600;
            letter-spacing: 0.5px;
            cursor: pointer;
            transition: all 0.3s;
            text-transform: uppercase;
            text-decoration: none;
            display: inline-block;
        }
        .btn-secondary:hover {
            background: #f9f7f4;
            border-color: #7A5C3E;
            color: #3a3a3a;
        }
        .info-box {
            background: #f9f7f4;
            border: 1px solid #e0d5c7;
            border-radius: 8px;
            padding: 20px;
            margin-bottom: 30px;
        }
        .info-box h3 {
            font-size: 13px;
            font-weight: 600;
            color: #5a4a3a;
            letter-spacing: 1px;
            margin-bottom: 10px;
            text-transform: uppercase;
        }
        .info-box ul {
            list-style: none;
            padding: 0;
        }
        .info-box ul li {
            font-size: 12px;
            color: #666;
            margin-bottom: 5px;
            padding-left: 15px;
            position: relative;
        }
        .info-box ul li:before {
            content: "•";
            color: #7A5C3E;
            position: absolute;
            left: 0;
        }
    </style>
</head>
<body>
    <header class="header">
        <div class="container">
            <div class="logo">
                <svg viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M10 70 Q10 75 15 75 L45 75 Q48 75 50 70 L50 85 Q48 90 45 90 L15 90 Q10 90 10 85 Z" fill="#7A5C3E"/>
                    <path d="M90 70 Q90 75 85 75 L55 75 Q52 75 50 70 L50 85 Q52 90 55 90 L85 90 Q90 90 90 85 Z" fill="#7A5C3E"/>
                    <path d="M50 70 L45 50 L50 30 L55 50 Z" fill="#5a4a3a"/>
                    <circle cx="50" cy="25" r="6" fill="#5a4a3a"/>
                    <ellipse cx="50" cy="15" rx="4" ry="7" fill="#7A5C3E"/>
                    <ellipse cx="42" cy="20" rx="4" ry="6" fill="#7A5C3E"/>
                    <ellipse cx="58" cy="20" rx="4" ry="6" fill="#7A5C3E"/>
                    <ellipse cx="38" cy="28" rx="5" ry="7" fill="#7A5C3E"/>
                    <ellipse cx="62" cy="28" rx="5" ry="7" fill="#7A5C3E"/>
                    <ellipse cx="35" cy="38" rx="4" ry="6" fill="#7A5C3E"/>
                    <ellipse cx="65" cy="38" rx="4" ry="6" fill="#7A5C3E"/>
                </svg>
                <span>Papyrus</span>
            </div>
            <nav class="nav">
                <a href="/home">Browse</a>
                <a href="/about">About</a>
                <a href="/stories">Stories</a>
            </nav>
            <div class="header-icons">
                <a href="/cart" class="icon-btn">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M9 2L7 6H21L19 2H9Z"/>
                        <path d="M7 6L5 20H19L21 6"/>
                    </svg>
                </a>
                <a href="/wishlist" class="icon-btn">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
                    </svg>
                </a>
                <a href="/profile" class="icon-btn">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                        <circle cx="12" cy="7" r="4"/>
                    </svg>
                </a>
            </div>
        </div>
    </header>

    <div class="breadcrumb">
        <div class="container">
            <a href="/home">SHOP</a> / <a href="/profile">PROFILE</a> / <span>SECURITY</span>
        </div>
    </div>

    <section class="profile-section">
        <div class="container">
            <h1 class="page-title">Change Password</h1>
            
            <div class="profile-layout">
                <%- include('../partials/profile-sidebar', { currentPage: 'password' }) %>

                <main class="main-content">
                    <div class="profile-card">
                        <div class="card-header">
                            <h2>Change Password</h2>
                            <a href="/profile" class="btn-secondary">BACK TO PROFILE</a>
                        </div>
                        
                        <div class="info-box">
                            <h3>Password Requirements</h3>
                            <ul>
                                <li>At least 8 characters long</li>
                                <li>Contains uppercase and lowercase letters</li>
                                <li>Contains at least one number</li>
                                <li>Contains at least one special character</li>
                            </ul>
                        </div>

                        <form id="changePasswordForm">
                            <div class="form-group">
                                <label for="currentPassword">Current Password</label>
                                <input type="password" id="currentPassword" name="currentPassword" required>
                            </div>

                            <div class="form-group">
                                <label for="newPassword">New Password</label>
                                <input type="password" id="newPassword" name="newPassword" required>
                                <div class="password-strength">
                                    <div class="strength-indicator"></div>
                                </div>
                                <p id="strengthText" style="font-size: 11px; color: #999; margin-top: 5px;">Password strength will appear here</p>
                            </div>

                            <div class="form-group">
                                <label for="confirmPassword">Confirm New Password</label>
                                <input type="password" id="confirmPassword" name="confirmPassword" required>
                                <p id="matchText" style="font-size: 11px; margin-top: 5px;"></p>
                            </div>

                            <div style="display: flex; gap: 15px; margin-top: 30px; padding-top: 30px; border-top: 1px solid #e0d5c7;">
                                <button type="submit" class="btn-edit">CHANGE PASSWORD</button>
                                <a href="/profile" class="btn-secondary">CANCEL</a>
                            </div>
                        </form>
                    </div>
                </main>
            </div>
        </div>
    </section>

    <footer class="footer">
        <div class="container">
            <div class="footer-content">
                <div class="footer-section">
                    <div class="footer-logo">
                        <svg viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <path d="M10 70 Q10 75 15 75 L45 75 Q48 75 50 70 L50 85 Q48 90 45 90 L15 90 Q10 90 10 85 Z" fill="currentColor"/>
                            <path d="M90 70 Q90 75 85 75 L55 75 Q52 75 50 70 L50 85 Q52 90 55 90 L85 90 Q90 90 90 85 Z" fill="currentColor"/>
                            <path d="M50 70 L45 50 L50 30 L55 50 Z" fill="currentColor"/>
                            <circle cx="50" cy="25" r="6" fill="currentColor"/>
                            <ellipse cx="50" cy="15" rx="4" ry="7" fill="currentColor"/>
                            <ellipse cx="42" cy="20" rx="4" ry="6" fill="currentColor"/>
                            <ellipse cx="58" cy="20" rx="4" ry="6" fill="currentColor"/>
                        </svg>
                        <span>PAPYRUS</span>
                    </div>
                    <p>Preserving literary heritage through sustainable book trading. Every book has a story, and every story deserves to be shared.</p>
                    <div class="social-links">
                        <a href="#"><svg viewBox="0 0 24 24" fill="currentColor"><circle cx="12" cy="12" r="10"/></svg></a>
                        <a href="#"><svg viewBox="0 0 24 24" fill="currentColor"><circle cx="12" cy="12" r="10"/></svg></a>
                        <a href="#"><svg viewBox="0 0 24 24" fill="currentColor"><circle cx="12" cy="12" r="10"/></svg></a>
                    </div>
                </div>
                <div class="footer-section">
                    <h4>Explore</h4>
                    <ul>
                        <li><a href="/browse">Browse Books</a></li>
                        <li><a href="/rare">Rare Editions</a></li>
                        <li><a href="/collections">Collections</a></li>
                        <li><a href="/gifts">Gift Cards</a></li>
                    </ul>
                </div>
                <div class="footer-section">
                    <h4>Community</h4>
                    <ul>
                        <li><a href="/about">About Us</a></li>
                        <li><a href="/stories">Reader Stories</a></li>
                        <li><a href="/events">Events</a></li>
                        <li><a href="/contact">Contact</a></li>
                    </ul>
                </div>
                <div class="footer-section">
                    <h4>Support</h4>
                    <ul>
                        <li><a href="/shipping">Shipping Info</a></li>
                        <li><a href="/guide">Condition Guide</a></li>
                        <li><a href="/privacy">Privacy Policy</a></li>
                        <li><a href="/terms">Terms of Service</a></li>
                    </ul>
                </div>
            </div>
            <div class="footer-bottom">
                <p>© 2024 PAPYRUS. PRESERVING STORIES SINCE 1974.</p>
            </div>
        </div>
    </footer>

    <script>
        function checkPasswordStrength(password) {
            let strength = 0;
            let feedback = [];

            if (password.length >= 8) strength++;
            else feedback.push('at least 8 characters');

            if (/[a-z]/.test(password) && /[A-Z]/.test(password)) strength++;
            else feedback.push('uppercase and lowercase letters');

            if (/\d/.test(password)) strength++;
            else feedback.push('at least one number');

            if (/[^A-Za-z0-9]/.test(password)) strength++;
            else feedback.push('at least one special character');

            const strengthBar = document.querySelector('.password-strength');
            const strengthText = document.getElementById('strengthText');

            strengthBar.className = 'password-strength';
            
            if (strength === 0) {
                strengthText.textContent = 'Password strength will appear here';
                strengthText.style.color = '#999';
            } else if (strength === 1) {
                strengthBar.classList.add('strength-weak');
                strengthText.textContent = 'Weak - Missing: ' + feedback.join(', ');
                strengthText.style.color = '#dc2626';
            } else if (strength === 2) {
                strengthBar.classList.add('strength-fair');
                strengthText.textContent = 'Fair - Missing: ' + feedback.join(', ');
                strengthText.style.color = '#d97706';
            } else if (strength === 3) {
                strengthBar.classList.add('strength-good');
                strengthText.textContent = 'Good - Missing: ' + feedback.join(', ');
                strengthText.style.color = '#8b7355';
            } else {
                strengthBar.classList.add('strength-strong');
                strengthText.textContent = 'Strong password!';
                strengthText.style.color = '#5a4a3a';
            }

            return strength;
        }

        function checkPasswordMatch() {
            const newPassword = document.getElementById('newPassword').value;
            const confirmPassword = document.getElementById('confirmPassword').value;
            const matchText = document.getElementById('matchText');

            if (confirmPassword === '') {
                matchText.textContent = '';
                return true;
            }

            if (newPassword === confirmPassword) {
                matchText.textContent = '✓ Passwords match';
                matchText.style.color = '#5a4a3a';
                return true;
            } else {
                matchText.textContent = '✗ Passwords do not match';
                matchText.style.color = '#dc2626';
                return false;
            }
        }

        document.getElementById('newPassword').addEventListener('input', (e) => {
            checkPasswordStrength(e.target.value);
            checkPasswordMatch();
        });

        document.getElementById('confirmPassword').addEventListener('input', checkPasswordMatch);

        document.getElementById('changePasswordForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            
            const formData = new FormData(e.target);
            const data = Object.fromEntries(formData.entries());
            
            // Validation
            if (!data.currentPassword || !data.newPassword || !data.confirmPassword) {
                Swal.fire({
                    title: 'Validation Error!',
                    text: 'All fields are required',
                    icon: 'error',
                    confirmButtonColor: '#5a4a3a'
                });
                return;
            }

            if (data.newPassword !== data.confirmPassword) {
                Swal.fire({
                    title: 'Password Mismatch!',
                    text: 'New password and confirm password do not match',
                    icon: 'error',
                    confirmButtonColor: '#5a4a3a'
                });
                return;
            }

            if (checkPasswordStrength(data.newPassword) < 4) {
                Swal.fire({
                    title: 'Weak Password!',
                    text: 'Please choose a stronger password',
                    icon: 'error',
                    confirmButtonColor: '#5a4a3a'
                });
                return;
            }

            try {
                const response = await fetch('/profile/change-password', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });
                
                const result = await response.json();
                
                if (result.success) {
                    Swal.fire({
                        title: 'Success!',
                        text: 'Password changed successfully',
                        icon: 'success',
                        confirmButtonColor: '#5a4a3a'
                    }).then(() => {
                        window.location.href = '/profile';
                    });
                } else {
                    Swal.fire({
                        title: 'Error!',
                        text: result.message,
                        icon: 'error',
                        confirmButtonColor: '#5a4a3a'
                    });
                }
            } catch (error) {
                Swal.fire({
                    title: 'Error!',
                    text: 'Failed to change password',
                    icon: 'error',
                    confirmButtonColor: '#5a4a3a'
                });
            }
        });
        
        history.pushState(null, null, location.href);
        window.onpopstate = function () {
            history.go(1);
        };
        
        window.addEventListener('beforeunload', function() {
            history.replaceState(null, null, location.href);
        });
    </script>
</body>
</html>