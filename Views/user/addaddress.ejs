    <!-- Main Content -->
    <div class="main-wrapper">
        <div class="container">
            <aside class="sidebar">
                <h2>My Account</h2>
                <nav class="sidebar-nav">
                    <a href="/profile"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg> OVERVIEW</a>
