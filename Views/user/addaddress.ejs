<!DOCTYPE html>
<html class="light" lang="en">
<head>
    <meta charset="utf-8"/>
    <meta content="width=device-width, initial-scale=1.0" name="viewport"/>
    <title>Pappyrus - Address Management</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <link href="https://fonts.googleapis.com/css2?family=Public+Sans:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
    <script>
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary": "#2D3B2D",
                        "secondary": "#5C4B3F",
                        "background-light": "#F5F3ED",
                        "background-dark": "#1A1D1A",
                        "accent": "#C2D2BD",
                        "sage-light": "#E9EBE4",
                    },
                    fontFamily: {
                        "display": ["Playfair Display", "serif"],
                        "sans": ["Inter", "sans-serif"],
                    },
                    borderRadius: {
                        "DEFAULT": "4px",
                        "lg": "4px",
                        "xl": "4px",
                        "full": "9999px"
                    },
                },
            },
        }
    </script>
</head>
<body class="dark:bg-background-dark font-display text-slate-900 dark:text-slate-100 min-h-screen bg-[#F5F3ED]">
<div class="flex h-screen overflow-hidden">
    <aside class="w-64 dark:bg-black flex-shrink-0 flex flex-col border-r bg-[#2D3B2D] border-white/10">
        <div class="p-6 flex items-center gap-3">
            <div class="size-8 bg-primary rounded flex items-center justify-center text-white">
                <span class="material-symbols-outlined">auto_stories</span>
            </div>
            <div class="flex flex-col">
                <h1 class="text-white text-lg font-bold leading-tight">Pappyrus</h1>
                <p class="text-white/60 text-xs font-medium uppercase tracking-wider">User Portal</p>
            </div>
        </div>
        <nav class="flex-1 px-4 py-4 space-y-1">
            <a class="flex items-center gap-3 px-3 py-2 text-white/70 hover:bg-white/10 rounded-lg transition-colors" href="/home">
                <span class="material-symbols-outlined">home</span>
                <span class="text-sm font-medium">Home</span>
            </a>
            <a class="flex items-center gap-3 px-3 py-2 text-white/70 hover:bg-white/10 rounded-lg transition-colors" href="/profile">
                <span class="material-symbols-outlined">person</span>
                <span class="text-sm font-medium">Profile</span>
            </a>
            <a class="flex items-center gap-3 px-3 py-2 bg-primary text-white rounded-lg transition-colors shadow-lg shadow-primary/20" href="/profile/address">
                <span class="material-symbols-outlined">location_on</span>
                <span class="text-sm font-medium">Address Management</span>
            </a>
        </nav>
        <div class="p-4 border-t border-white/10">
            <div class="flex items-center gap-3 p-2 rounded-lg hover:bg-white/5 cursor-pointer">
                <div class="size-10 rounded-full bg-primary/20 flex items-center justify-center text-white font-bold">
                    <%= user.firstName.charAt(0) %><%= user.lastName.charAt(0) %>
                </div>
                <div class="flex-1 overflow-hidden">
                    <p class="text-white text-sm font-semibold truncate"><%= user.firstName %> <%= user.lastName %></p>
                    <p class="text-white/50 text-xs truncate"><%= user.email %></p>
                </div>
            </div>
        </div>
    </aside>

    <main class="flex-1 flex flex-col overflow-y-auto">
        <header class="h-16 flex items-center justify-between px-8 border-b border-slate-200 dark:border-slate-800 bg-white/50 dark:bg-background-dark/50 backdrop-blur-md sticky top-0 z-10 bg-[#F5F3ED]/80">
            <div class="flex-1 max-w-xl">
                <h2 class="text-lg font-bold">Address Management</h2>
            </div>
            <div class="flex items-center gap-4 ml-8">
                <a href="/logout" class="p-2 text-slate-500 hover:bg-slate-100 dark:hover:bg-slate-800 rounded-full">
                    <span class="material-symbols-outlined">logout</span>
                </a>
            </div>
        </header>

        <div class="p-8 max-w-7xl mx-auto w-full">
            <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-8">
                <div>
                    <h2 class="text-3xl font-extrabold tracking-tight text-slate-900 dark:text-slate-100">My Addresses</h2>
                    <p class="text-slate-500 dark:text-slate-400 mt-1">Manage your delivery and billing addresses.</p>
                </div>
                <button onclick="showAddForm()" class="flex items-center gap-2 bg-[#2D3B2D] hover:bg-[#1e291e] text-white px-5 py-2.5 rounded font-bold transition-all shadow-md active:scale-95">
                    <span class="material-symbols-outlined">add</span>Add New Address
                </button>
            </div>

            <div id="addressGrid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-12">
            </div>

            <div id="addForm" class="hidden bg-white dark:bg-slate-900 rounded-xl border border-slate-200 dark:border-slate-800 shadow-sm overflow-hidden p-8">
                <h3 class="text-xl font-bold mb-6">Add New Address</h3>
                <form id="addressForm" class="space-y-4">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div>
                            <label class="block text-xs font-bold text-slate-500 uppercase tracking-widest mb-2">Street Address</label>
                            <input name="street" required class="w-full px-4 py-3 border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-900/50 focus:ring-1 focus:ring-primary focus:border-primary transition-all outline-none rounded-sm text-sm" type="text"/>
                        </div>
                        <div>
                            <label class="block text-xs font-bold text-slate-500 uppercase tracking-widest mb-2">City</label>
                            <input name="city" required class="w-full px-4 py-3 border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-900/50 focus:ring-1 focus:ring-primary focus:border-primary transition-all outline-none rounded-sm text-sm" type="text"/>
                        </div>
                        <div>
                            <label class="block text-xs font-bold text-slate-500 uppercase tracking-widest mb-2">State</label>
                            <input name="state" required class="w-full px-4 py-3 border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-900/50 focus:ring-1 focus:ring-primary focus:border-primary transition-all outline-none rounded-sm text-sm" type="text"/>
                        </div>
                        <div>
                            <label class="block text-xs font-bold text-slate-500 uppercase tracking-widest mb-2">Zip Code</label>
                            <input name="zipCode" required class="w-full px-4 py-3 border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-900/50 focus:ring-1 focus:ring-primary focus:border-primary transition-all outline-none rounded-sm text-sm" type="text"/>
                        </div>
                        <div class="md:col-span-2">
                            <label class="block text-xs font-bold text-slate-500 uppercase tracking-widest mb-2">Country</label>
                            <input name="country" required class="w-full px-4 py-3 border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-900/50 focus:ring-1 focus:ring-primary focus:border-primary transition-all outline-none rounded-sm text-sm" type="text"/>
                        </div>
                    </div>
                    <div class="flex gap-3 pt-4">
                        <button type="submit" class="flex-1 py-3 bg-primary text-white text-xs font-bold uppercase tracking-widest rounded hover:bg-slate-800 transition-all">Save Address</button>
                        <button type="button" onclick="hideAddForm()" class="px-6 py-3 text-xs font-bold uppercase tracking-widest text-slate-500 hover:text-primary transition-colors">Cancel</button>
                    </div>
                </form>
            </div>
        </div>
    </main>
</div>

<script>
    function showAddForm() {
        document.getElementById('addForm').classList.remove('hidden');
    }

    function hideAddForm() {
        document.getElementById('addForm').classList.add('hidden');
        document.getElementById('addressForm').reset();
    }

    document.getElementById('addressForm').addEventListener('submit', async (e) => {
        e.preventDefault();
        const formData = new FormData(e.target);
        const data = Object.fromEntries(formData);

        try {
            const response = await fetch('/profile/address/add', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            });

            const result = await response.json();
            if (result.success) {
                Swal.fire({
                    title: 'Success!',
                    text: 'Address added successfully',
                    icon: 'success',
                    confirmButtonText: 'OK',
                    confirmButtonColor: '#2D3B2D'
                }).then(() => {
                    location.reload();
                });
            } else {
                Swal.fire({
                    title: 'Error!',
                    text: result.message || 'Failed to add address',
                    icon: 'error',
                    confirmButtonText: 'OK',
                    confirmButtonColor: '#2D3B2D'
                });
            }
        } catch (error) {
            console.error('Error:', error);
            Swal.fire({
                title: 'Error!',
                text: 'An error occurred',
                icon: 'error',
                confirmButtonText: 'OK',
                confirmButtonColor: '#2D3B2D'
            });
        }
    });
</script>
</body>
</html>
