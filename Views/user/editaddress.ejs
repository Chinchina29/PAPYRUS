<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Papyrus - Edit Address</title>
    <link rel="stylesheet" href="/css/profile.css">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <style>
      .form-group { margin-bottom: 20px; }
      .form-group label {
        display: block; font-size: 11px; font-weight: 600; color: #999;
        letter-spacing: 1px; margin-bottom: 8px; text-transform: uppercase;
      }
      .form-group input, .form-group select {
        width: 100%; padding: 12px 15px; border: 1px solid #e0d5c7;
        border-radius: 4px; font-size: 14px; color: #3a3a3a;
        background: white; transition: border-color 0.3s;
      }
      .form-group input:focus, .form-group select:focus { outline: none; border-color: #7A5C3E; }
      .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
      .form-row-3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 20px; }
      .btn-primary {
        padding: 12px 30px; background: #3a3a3a; color: white; border: none;
        border-radius: 4px; font-size: 12px; font-weight: 600; letter-spacing: 0.5px;
        cursor: pointer; transition: background 0.3s; text-transform: uppercase;
      }
      .btn-primary:hover { background: #2a2a2a; }
      .btn-secondary {
        padding: 12px 30px; background: transparent; color: #666;
        border: 1px solid #e0d5c7; border-radius: 4px; font-size: 12px;
        font-weight: 600; letter-spacing: 0.5px; cursor: pointer; transition: all 0.3s;
        text-transform: uppercase; text-decoration: none; display: inline-block;
      }
      .btn-secondary:hover { background: #f9f7f4; border-color: #7A5C3E; color: #3a3a3a; }
      .checkbox-group { display: flex; align-items: center; gap: 10px; margin-top: 20px; }
      .checkbox-group input[type="checkbox"] { width: auto; margin: 0; }
      .checkbox-group label { margin: 0; font-size: 14px; color: #3a3a3a; text-transform: none; font-weight: 400; }
    </style>
</head>
<body>
    <header class="header">
      <div class="container">
        <div class="logo">
          <svg viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M10 70 Q10 75 15 75 L45 75 Q48 75 50 70 L50 85 Q48 90 45 90 L15 90 Q10 90 10 85 Z" fill="#7A5C3E"/>
            <path d="M90 70 Q90 75 85 75 L55 75 Q52 75 50 70 L50 85 Q52 90 55 90 L85 90 Q90 90 90 85 Z" fill="#7A5C3E"/>
            <path d="M50 70 L45 50 L50 30 L55 50 Z" fill="#5a4a3a"/>
            <circle cx="50" cy="25" r="6" fill="#5a4a3a"/>
            <ellipse cx="50" cy="15" rx="4" ry="7" fill="#7A5C3E"/>
            <ellipse cx="42" cy="20" rx="4" ry="6" fill="#7A5C3E"/>
            <ellipse cx="58" cy="20" rx="4" ry="6" fill="#7A5C3E"/>
            <ellipse cx="38" cy="28" rx="5" ry="7" fill="#7A5C3E"/>
            <ellipse cx="62" cy="28" rx="5" ry="7" fill="#7A5C3E"/>
            <ellipse cx="35" cy="38" rx="4" ry="6" fill="#7A5C3E"/>
            <ellipse cx="65" cy="38" rx="4" ry="6" fill="#7A5C3E"/>
          </svg>
          <span>Papyrus</span>
        </div>
        <nav class="nav">
          <a href="/home">Browse</a>
          <a href="/about">About</a>
          <a href="/stories">Stories</a>
        </nav>
        <div class="header-icons">
          <a href="/cart" class="icon-btn">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M9 2L7 6H21L19 2H9Z"/><path d="M7 6L5 20H19L21 6"/>
            </svg>
          </a>
          <a href="/wishlist" class="icon-btn">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
            </svg>
          </a>
          <a href="/profile" class="icon-btn">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>
            </svg>
          </a>
        </div>
      </div>
    </header>

    <div class="breadcrumb">
      <div class="container">
        <a href="/home">SHOP</a> / <a href="/profile">PROFILE</a> /
        <a href="/profile/addresses">ADDRESSES</a> / <span>EDIT ADDRESS</span>
      </div>
    </div>

    <section class="profile-section">
      <div class="container">
        <h1 class="page-title">My Account</h1>
        <div class="profile-layout">
          <%- include('../partials/profile-sidebar', { currentPage: 'addresses' }) %>
          <main class="main-content">
            <div class="profile-card">
              <div class="card-header">
                <h2>Edit Address</h2>
                <a href="/profile/addresses" class="btn-secondary">BACK TO ADDRESSES</a>
              </div>
              <form id="addressForm">
                <div class="form-row">
                  <div class="form-group">
                    <label for="fullName">Full Name</label>
                    <input type="text" id="fullName" name="fullName" value="<%= address.fullName %>">
                  </div>
                  <div class="form-group">
                    <label for="phone">Phone Number</label>
                    <input type="tel" id="phone" name="phone" value="<%= address.phone %>">
                  </div>
                </div>
                <div class="form-group">
                  <label for="addressLine1">Address Line 1</label>
                  <input type="text" id="addressLine1" name="addressLine1" value="<%= address.addressLine1 %>">
                </div>
                <div class="form-group">
                  <label for="addressLine2">Address Line 2 (Optional)</label>
                  <input type="text" id="addressLine2" name="addressLine2" value="<%= address.addressLine2 || '' %>">
                </div>
                <div class="form-row-3">
                  <div class="form-group">
                    <label for="city">City</label>
                    <input type="text" id="city" name="city" value="<%= address.city %>">
                  </div>
                  <div class="form-group">
                    <label for="state">State</label>
                    <input type="text" id="state" name="state" value="<%= address.state %>">
                  </div>
                  <div class="form-group">
                    <label for="postalCode">Postal Code</label>
                    <input type="text" id="postalCode" name="postalCode" value="<%= address.postalCode %>">
                  </div>
                </div>
                <div class="form-row">
                  <div class="form-group">
                    <label for="country">Country</label>
                    <input type="text" id="country" name="country" value="<%= address.country %>">
                  </div>
                  <div class="form-group">
                    <label for="type">Address Type</label>
                    <select id="type" name="type">
                      <option value="home" <%= address.type === 'home' ? 'selected' : '' %>>🏠 Home</option>
                      <option value="work" <%= address.type === 'work' ? 'selected' : '' %>>🏢 Work</option>
                      <option value="other" <%= address.type === 'other' ? 'selected' : '' %>>📍 Other</option>
                    </select>
                  </div>
                </div>
                <div class="checkbox-group">
                  <input type="checkbox" id="isDefault" name="isDefault" <%= address.isDefault ? 'checked' : '' %>>
                  <label for="isDefault">Set as default address</label>
                </div>
                <div style="display: flex; gap: 15px; margin-top: 30px; padding-top: 30px; border-top: 1px solid #e0d5c7;">
                  <button type="submit" class="btn-primary">Update Address</button>
                  <a href="/profile/addresses" class="btn-secondary">Cancel</a>
                </div>
              </form>
            </div>
          </main>
        </div>
      </div>
    </section>

    <footer class="footer">
      <div class="container">
        <div class="footer-content">
          <div class="footer-section">
            <div class="footer-logo">
              <svg viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M10 70 Q10 75 15 75 L45 75 Q48 75 50 70 L50 85 Q48 90 45 90 L15 90 Q10 90 10 85 Z" fill="currentColor"/>
                <path d="M90 70 Q90 75 85 75 L55 75 Q52 75 50 70 L50 85 Q52 90 55 90 L85 90 Q90 90 90 85 Z" fill="currentColor"/>
                <path d="M50 70 L45 50 L50 30 L55 50 Z" fill="currentColor"/>
                <circle cx="50" cy="25" r="6" fill="currentColor"/>
                <ellipse cx="50" cy="15" rx="4" ry="7" fill="currentColor"/>
                <ellipse cx="42" cy="20" rx="4" ry="6" fill="currentColor"/>
                <ellipse cx="58" cy="20" rx="4" ry="6" fill="currentColor"/>
              </svg>
              <span>PAPYRUS</span>
            </div>
            <p>Preserving literary heritage through sustainable book trading.</p>
          </div>
          <div class="footer-section">
            <h4>Explore</h4>
            <ul>
              <li><a href="/browse">Browse Books</a></li>
              <li><a href="/rare">Rare Editions</a></li>
              <li><a href="/collections">Collections</a></li>
              <li><a href="/gifts">Gift Cards</a></li>
            </ul>
          </div>
          <div class="footer-section">
            <h4>Community</h4>
            <ul>
              <li><a href="/about">About Us</a></li>
              <li><a href="/stories">Reader Stories</a></li>
              <li><a href="/events">Events</a></li>
              <li><a href="/contact">Contact</a></li>
            </ul>
          </div>
          <div class="footer-section">
            <h4>Support</h4>
            <ul>
              <li><a href="/shipping">Shipping Info</a></li>
              <li><a href="/privacy">Privacy Policy</a></li>
              <li><a href="/terms">Terms of Service</a></li>
            </ul>
          </div>
        </div>
        <div class="footer-bottom">
          <p>© 2024 PAPYRUS. PRESERVING STORIES SINCE 1974.</p>
        </div>
      </div>
    </footer>

    <script>
      document.getElementById('addressForm').addEventListener('submit', async (e) => {
        e.preventDefault();
        const formData = new FormData(e.target);
        const data = Object.fromEntries(formData.entries());
        data.isDefault = document.getElementById('isDefault').checked;

        if (!data.fullName || !data.phone || !data.addressLine1 || !data.city || !data.state || !data.postalCode || !data.country) {
          Swal.fire({ title: 'Validation Error!', text: 'Please fill all required fields', icon: 'error', confirmButtonColor: '#5a4a3a' });
          return;
        }
        if (!/^[6-9]\d{9}$/.test(data.phone)) {
          Swal.fire({ title: 'Invalid Phone!', text: 'Please enter a valid Indian phone number', icon: 'error', confirmButtonColor: '#5a4a3a' });
          return;
        }
        if (!/^\d{6}$/.test(data.postalCode)) {
          Swal.fire({ title: 'Invalid Postal Code!', text: 'Please enter a valid 6-digit postal code', icon: 'error', confirmButtonColor: '#5a4a3a' });
          return;
        }

        try {
          const addressId = '<%= address._id %>';
          const response = await fetch(`/profile/addresses/${addressId}`, {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data)
          });
          const result = await response.json();
          if (result.success) {
            Swal.fire({ title: 'Success!', text: 'Address updated successfully', icon: 'success', confirmButtonColor: '#5a4a3a' })
              .then(() => { window.location.href = '/profile/addresses'; });
          } else {
            Swal.fire({ title: 'Error!', text: result.message, icon: 'error', confirmButtonColor: '#5a4a3a' });
          }
        } catch (error) {
          Swal.fire({ title: 'Error!', text: 'Failed to update address', icon: 'error', confirmButtonColor: '#5a4a3a' });
        }
      });

      history.pushState(null, null, location.href);
      window.onpopstate = function () { history.go(1); };
      window.addEventListener('beforeunload', function () { history.replaceState(null, null, location.href); });
    </script>
</body>
</html>