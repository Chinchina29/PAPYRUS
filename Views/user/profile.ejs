                    <div class="profile-card">
                        <div class="card-header">
                            <h2>Personal Information</h2>
                            <a href="/editprofile" class="btn-edit">EDIT PROFILE</a>
                        </div>
                        
                        <div class="profile-info">
                            <div class="profile-avatar">
                                <div class="avatar-circle">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                                        <circle cx="12" cy="7" r="4"/>
                                    </svg>
                                </div>
                                <div class="profile-name">
                                    <h3>Julian Barnes</h3>
                                    <p>AVID COLLECTOR</p>
                                </div>
                            </div>

                            <div class="info-grid">
                                <div class="info-item">
                                    <label>EMAIL ADDRESS</label>
                                    <p>j.barnes@bibliophilo.com</p>
                                </div>
                                <div class="info-item">
                                    <label>PHONE NUMBER</label>
                                    <p>+1 (555) 234-5678</p>
                                </div>
                                <div class="info-item">
                                    <label>DATE OF BIRTH</label>
                                    <p>January 19, 1982</p>
                                </div>
                                <div class="info-item">
                                    <label>GENDER</label>
                                    <p>Male</p>
                                </div>
                                <div class="info-item">
                                    <label>LANGUAGE PREFERENCE</label>
                                    <p>English (UK), French</p>
                                </div>
                                <div class="info-item">
                                    <label>JOINED DATE</label>
                                    <p>November 12, 2023</p>
                                </div>
                            </div>
                        </div>

                        <div class="bio-section">
                            <h3>BIO / ABOUT ME</h3>
                            <p>"A lifelong devotee of the written word, specializing in early 20th-century modernism and forgotten Victorian periodicals. I believe every book is a vessel of history, and I'm currently on a quest to complete my collection of first-edition F. Scott Fitzgerald novels. When I'm not browsing the stacks at Papyrus, you can find me at a quiet corner café with a flat white and a well-worn copy of Ulysses."</p>
                        </div>
                    </div>

                    <div class="literary-profile">
                        <h2>Literary Profile</h2>
                        <div class="literary-grid">
                            <div class="literary-card">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M4 19.5C4 18.837 4.26339 18.2011 4.73223 17.7322C5.20107 17.2634 5.83696 17 6.5 17H20"/>
                                    <path d="M6.5 2H20V22H6.5C5.83696 22 5.20107 21.7366 4.73223 21.2678C4.26339 20.7989 4 20.163 4 19.5V4.5C4 3.83696 4.26339 3.20107 4.73223 2.73223C5.20107 2.26339 5.83696 2 6.5 2Z"/>
                                </svg>
