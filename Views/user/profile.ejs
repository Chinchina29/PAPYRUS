            <h1 class="page-title">My Account</h1>
            
            <div class="profile-layout">
                <!-- Sidebar -->
                <aside class="sidebar">
                    <nav class="sidebar-nav">
                        <a href="#overview" class="nav-item active">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
