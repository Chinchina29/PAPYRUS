<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Page Not Found - Papyrus</title>
    <link rel="stylesheet" href="/css/error.css">
</head>
<body>
    <div class="error-container">
        <div class="error-content">
            <div class="logo">
                <svg viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <!-- Open Book -->
                    <path d="M10 70 Q10 75 15 75 L45 75 Q48 75 50 72 L50 85 Q48 88 45 88 L15 88 Q10 88 10 83 Z" fill="#2d5016" stroke="#fff" stroke-width="1.5"/>
                    <path d="M90 70 Q90 75 85 75 L55 75 Q52 75 50 72 L50 85 Q52 88 55 88 L85 88 Q90 88 90 83 Z" fill="#2d5016" stroke="#fff" stroke-width="1.5"/>
                    
                    <!-- Tree trunk/person -->
                    <path d="M50 72 L45 50 L50 35 L55 50 Z" fill="#2d5016"/>
                    <circle cx="50" cy="30" r="6" fill="#2d5016"/>
                    
                    <!-- Leaves -->
                    <ellipse cx="50" cy="15" rx="4" ry="7" fill="#228B22"/>
                    <ellipse cx="42" cy="22" rx="4" ry="6" fill="#228B22"/>
                    <ellipse cx="58" cy="22" rx="4" ry="6" fill="#228B22"/>
                    <ellipse cx="35" cy="28" rx="5" ry="7" fill="#228B22"/>
                    <ellipse cx="65" cy="28" rx="5" ry="7" fill="#228B22"/>
                    <ellipse cx="28" cy="35" rx="5" ry="8" fill="#228B22"/>
                    <ellipse cx="72" cy="35" rx="5" ry="8" fill="#228B22"/>
                    <ellipse cx="38" cy="38" rx="4" ry="6" fill="#228B22"/>
                    <ellipse cx="62" cy="38" rx="4" ry="6" fill="#228B22"/>
                    <ellipse cx="45" cy="25" rx="3" ry="5" fill="#228B22"/>
                    <ellipse cx="55" cy="25" rx="3" ry="5" fill="#228B22"/>
                    <ellipse cx="50" cy="32" rx="5" ry="7" fill="#228B22"/>
                    <ellipse cx="32" cy="42" rx="4" ry="6" fill="#228B22"/>
                    <ellipse cx="68" cy="42" rx="4" ry="6" fill="#228B22"/>
                    <ellipse cx="25" cy="48" rx="3" ry="5" fill="#228B22"/>
                    <ellipse cx="75" cy="48" rx="3" ry="5" fill="#228B22"/>
                </svg>
                <h2>Papyrus</h2>
            </div>

            <div class="error-illustration">
                <div class="error-number">404</div>
                <div class="error-books">
                    <div class="book book-1"></div>
                    <div class="book book-2"></div>
                    <div class="book book-3"></div>
                </div>
            </div>

            <h1 class="error-title">Page Not Found</h1>
            <p class="error-message">
                Oops! The page you're looking for seems to have wandered off like a book in a library. 
                It might have been moved, deleted, or you entered the wrong URL.
            </p>

            <div class="error-actions">
                <a href="/" class="btn btn-primary">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
                        <polyline points="9,22 9,12 15,12 15,22"/>
                    </svg>
                    Go Home
                </a>
                <button onclick="history.back()" class="btn btn-secondary">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M19 12H5M12 19l-7-7 7-7"/>
                    </svg>
                    Go Back
                </button>
            </div>

            <div class="helpful-links">
                <h3>Popular Pages</h3>
                <ul>
                    <li><a href="/">Home</a></li>
                    <li><a href="/login">Sign In</a></li>
                    <li><a href="/signup">Create Account</a></li>
                    <li><a href="/profile">My Profile</a></li>
                </ul>
            </div>
        </div>
    </div>
</body>
</html>