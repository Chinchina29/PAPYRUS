<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Unauthorized - Papyrus</title>
    <link rel="stylesheet" href="/css/error.css">
</head>
<body>
    <div class="error-container">
        <div class="error-content">
            <div class="logo">
                <svg viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M10 70 Q10 75 15 75 L45 75 Q48 75 50 72 L50 85 Q48 88 45 88 L15 88 Q10 88 10 83 Z" fill="#2d5016" stroke="#fff" stroke-width="1.5"/>
                    <path d="M90 70 Q90 75 85 75 L55 75 Q52 75 50 72 L50 85 Q52 88 55 88 L85 88 Q90 88 90 83 Z" fill="#2d5016" stroke="#fff" stroke-width="1.5"/>
                    <path d="M50 72 L45 50 L50 35 L55 50 Z" fill="#2d5016"/>
                    <circle cx="50" cy="30" r="6" fill="#2d5016"/>
                    <ellipse cx="50" cy="15" rx="4" ry="7" fill="#228B22"/>
                    <ellipse cx="42" cy="22" rx="4" ry="6" fill="#228B22"/>
                    <ellipse cx="58" cy="22" rx="4" ry="6" fill="#228B22"/>
                </svg>
                <h2>Papyrus</h2>
            </div>

            <div class="error-illustration">
                <div class="error-number" style="color: #f39c12;">401</div>
                <div class="error-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M9 12l2 2 4-4"/>
                        <path d="M21 12c-1 0-3-1-3-3s2-3 3-3 3 1 3 3-2 3-3 3"/>
                        <path d="M3 12c1 0 3-1 3-3s-2-3-3-3-3 1-3 3 2 3 3 3"/>
                        <path d="M13 12h3l2-2-2-2h-3"/>
                        <path d="M11 12H8l-2-2 2-2h3"/>
                    </svg>
                </div>
            </div>

            <h1 class="error-title">Authentication Required</h1>
            <p class="error-message">
                You need to be logged in to access this page. Please sign in with your account to continue.
            </p>

            <div class="error-actions">
                <a href="/login" class="btn btn-primary">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/>
                        <polyline points="10,17 15,12 10,7"/>
                        <line x1="15" y1="12" x2="3" y2="12"/>
                    </svg>
                    Sign In
                </a>
                <a href="/signup" class="btn btn-secondary">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                        <circle cx="8.5" cy="7" r="4"/>
                        <line x1="20" y1="8" x2="20" y2="14"/>
                        <line x1="23" y1="11" x2="17" y2="11"/>
                    </svg>
                    Create Account
                </a>
            </div>
        </div>
    </div>
</body>
</html>